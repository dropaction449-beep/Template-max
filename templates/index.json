    "custom_liquid_EPxnHT": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div id=\"shopify-section-comment-ca-fonctionne\" class=\"shopify-section\">\n  <section class=\"how-it-works-section\" style=\"background: #FFFFFF;\">\n    <div class=\"how-it-works-section__inner page-width\">\n\n      <!-- ═══════════════════════════════\n           COMMENT ÇA FONCTIONNE\n           ═══════════════════════════════ -->\n      <div class=\"how-it-works\">\n        <!-- Titre -->\n        <p class=\"how-it-works__kicker\">Technologie infrarouge brevetée</p>\n        <h2 class=\"how-it-works__title\">Comment Moisissure-CLEAN agit sur le mur ?</h2>\n\n        <!-- GIF + Bulles explicatives -->\n        <div class=\"how-it-works__content\">\n          \n          <!-- GIF central -->\n          <div class=\"how-it-works__gif-wrapper\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0990/1765/4619/files/Vidoproduit00-ezgif.com-video-to-gif-converter.gif?v=1770818164\" alt=\"Fonctionnement\" class=\"how-it-works__gif\"><br>\n            \n            <!-- Bulle 1 - Haut gauche -->\n            <div class=\"bubble bubble-1\">\n              <div class=\"bubble-number\">1</div>\n              <p class=\"bubble-text\">Le panneau émet des <strong>ondes infrarouges</strong> qui pénètrent le mur</p>\n            </div>\n\n            <!-- Bulle 2 - Milieu droite -->\n            <div class=\"bubble bubble-2\">\n              <div class=\"bubble-number\">2</div>\n              <p class=\"bubble-text\">L'humidité <strong>s'évapore en profondeur</strong> de l'intérieur vers l'extérieur</p>\n            </div>\n\n            <!-- Bulle 3 - Bas gauche -->\n            <div class=\"bubble bubble-3\">\n              <div class=\"bubble-number\">3</div>\n              <p class=\"bubble-text\">Le mur reste <strong>sec en permanence</strong> et la moisissure disparaît</p>\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      <!-- ═══════════════════════════════\n           SECTION AVANT/APRÈS\n           ═══════════════════════════════ -->\n      <div class=\"before-after-section\">\n        \n        <!-- Titre section avant/après -->\n        <p class=\"before-after__kicker\">Résultats prouvés</p>\n        <h2 class=\"before-after__title\">Des transformations réelles, des résultats visibles</h2>\n        \n        <!-- Image avant/après -->\n        <div class=\"before-after__image-wrapper\">\n          <img \n            src=\"https://cdn.shopify.com/s/files/1/0990/1765/4619/files/Firefly_Gemini_Flash_traduit_l_image_en_francais_190320.png?v=1769995047\" \n            alt=\"Avant et après utilisation de Moisissure-CLEAN - Transformation complète des murs moisis\" \n            class=\"before-after__image\"\n            loading=\"lazy\"\n          >\n        </div>\n        \n        <!-- Texte sous l'image -->\n        <p class=\"before-after__caption\">\n          <strong>Résultats après 4-6 semaines</strong> d'utilisation continue. Photos réelles sans retouche.\n        </p>\n      </div>\n\n    </div>\n  </section>\n</div>\n\n<style>\n/* ═══════════════════════════════\n   COMMENT ÇA FONCTIONNE - STYLES\n   ═══════════════════════════════ */\n.how-it-works-section {\n  padding: 40px 20px;\n  background: #FFFFFF;\n}\n\n@media (max-width: 749px) {\n  .how-it-works-section {\n    padding: 30px 16px;\n  }\n}\n\n.how-it-works-section__inner {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.how-it-works {\n  margin-bottom: 0;\n}\n\n.how-it-works__kicker {\n  font-size: 14px;\n  color: #00A4C1;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  text-align: center;\n  margin: 0 0 8px;\n}\n\n.how-it-works__title {\n  font-size: 28px;\n  font-weight: 700;\n  color: #1A1A1A;\n  text-align: center;\n  line-height: 1.3;\n  margin: 0 0 30px;\n}\n\n@media (max-width: 749px) {\n  .how-it-works__kicker {\n    font-size: 12px;\n  }\n  \n  .how-it-works__title {\n    font-size: 20px;\n    margin-bottom: 20px;\n  }\n}\n\n/* GIF avec bulles positionnées */\n.how-it-works__gif-wrapper {\n  position: relative;\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n.how-it-works__gif {\n  width: 100%;\n  height: auto;\n  border-radius: 12px;\n  display: block;\n}\n\n@media (max-width: 749px) {\n  .how-it-works__gif-wrapper {\n    max-width: 100%;\n  }\n  \n  .how-it-works__gif {\n    border-radius: 8px;\n  }\n}\n\n/* ═══════════════════════════════\n   BULLES EXPLICATIVES\n   ═══════════════════════════════ */\n.bubble {\n  position: absolute;\n  background: #FFFFFF;\n  border: 2px solid #00A4C1;\n  border-radius: 10px;\n  padding: 10px 15px;\n  display: flex;\n  align-items: flex-start;\n  gap: 10px;\n  max-width: 240px;\n  z-index: 10;\n}\n\n.bubble-number {\n  flex-shrink: 0;\n  width: 28px;\n  height: 28px;\n  background: #00A4C1;\n  color: #FFFFFF;\n  font-size: 16px;\n  font-weight: 700;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.bubble-text {\n  font-size: 13px;\n  color: #333;\n  line-height: 1.4;\n  margin: 0;\n  padding-top: 3px;\n}\n\n.bubble-text strong {\n  color: #00A4C1;\n  font-weight: 700;\n}\n\n/* Positions des bulles sur DESKTOP */\n.bubble-1 {\n  top: 5%;\n  left: -15%;\n}\n\n.bubble-2 {\n  top: 40%;\n  right: -18%;\n}\n\n.bubble-3 {\n  bottom: 10%;\n  left: -15%;\n}\n\n/* Positions des bulles sur MOBILE */\n@media (max-width: 989px) {\n  .bubble {\n    position: static;\n    max-width: 100%;\n    margin-bottom: 12px;\n  }\n  \n  /* Empiler les bulles sous le GIF */\n  .how-it-works__content {\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n  \n  .bubble-number {\n    width: 26px;\n    height: 26px;\n    font-size: 14px;\n  }\n  \n  .bubble-text {\n    font-size: 12px;\n  }\n}\n\n/* ═══════════════════════════════\n   SECTION AVANT/APRÈS\n   ═══════════════════════════════ */\n.before-after-section {\n  margin-top: 50px;\n  padding-top: 30px;\n}\n\n@media (max-width: 749px) {\n  .before-after-section {\n    margin-top: 35px;\n    padding-top: 20px;\n  }\n}\n\n/* Textes section avant/après */\n.before-after__kicker {\n  font-size: 14px;\n  color: #00A4C1;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  text-align: center;\n  margin: 0 0 8px;\n}\n\n.before-after__title {\n  font-size: 26px;\n  font-weight: 700;\n  color: #1A1A1A;\n  text-align: center;\n  line-height: 1.3;\n  margin: 0 0 25px;\n}\n\n@media (max-width: 749px) {\n  .before-after__kicker {\n    font-size: 12px;\n  }\n  \n  .before-after__title {\n    font-size: 20px;\n    margin-bottom: 20px;\n  }\n}\n\n/* Image avant/après */\n.before-after__image-wrapper {\n  max-width: 900px;\n  margin: 0 auto 15px;\n  border-radius: 10px;\n  overflow: hidden;\n  border: 1px solid #E0E0E0;\n}\n\n.before-after__image {\n  width: 100%;\n  height: auto;\n  display: block;\n}\n\n@media (max-width: 749px) {\n  .before-after__image-wrapper {\n    border-radius: 8px;\n    margin-bottom: 12px;\n  }\n}\n\n/* Caption sous l'image */\n.before-after__caption {\n  text-align: center;\n  font-size: 13px;\n  color: #666;\n  line-height: 1.5;\n  margin: 0 auto;\n  max-width: 600px;\n}\n\n.before-after__caption strong {\n  color: #00A4C1;\n  font-weight: 700;\n}\n\n@media (max-width: 749px) {\n  .before-after__caption {\n    font-size: 12px;\n    padding: 0 15px;\n  }\n}\n</style>",
