or:#fff;}\n  #calc-template--25831865057611__mold_calculator_h_qH63id .card{\n    background: var(--bg-card); border-radius: var(--radius);\n    box-shadow: var(--shadow); padding: 16px;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .card h3{ margin:0 0 4px 0; font-size: 18px; font-weight:800; }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .total{\n    font-size: 44px; font-weight:800; line-height:1; margin: 4px 0 10px;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .muted{color:var(--muted);font-size:13px;line-height:1.45;}\n  #calc-template--25831865057611__mold_calculator_h_qH63id .right .card { text-align: left; }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .right .card .btn { justify-content: flex-start; }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .btn{\n    display: inline-flex; width: auto; justify-content: flex-start;\n    align-items: center; padding: 12px 14px; border-radius: 12px;\n    text-decoration: none; font-weight: 800; background: var(--accent);\n    color: #fff; transition: transform .05s ease, filter .2s ease;\n    margin-top: 10px; cursor: pointer;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .btn:hover{filter: brightness(.95);}\n  #calc-template--25831865057611__mold_calculator_h_qH63id .btn:active{transform: translateY(1px);}\n  #calc-template--25831865057611__mold_calculator_h_qH63id select{\n    width:100%;padding:12px 14px;border-radius:12px;border:1px solid #E5E7EB;\n    background:#fff url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' fill='none' stroke='%236B7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='2'><polyline points='6 9 12 15 18 9'/></svg>\") no-repeat right 14px center/18px;\n    font-weight:600;font-size:14px;appearance:none;-webkit-appearance:none;-moz-appearance:none;\n    box-shadow:0 2px 6px rgba(0,0,0,0.04);transition:border-color .2s, box-shadow .2s;\n    color:#0F172A !important;-webkit-text-fill-color:#0F172A !important;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id select option{color:#0F172A;background:#fff;}\n  #calc-template--25831865057611__mold_calculator_h_qH63id select:hover{border-color:var(--accent);box-shadow:0 2px 8px rgba(0,0,0,0.08);}\n  #calc-template--25831865057611__mold_calculator_h_qH63id select:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(31,163,170,0.2);color:#0F172A !important;-webkit-text-fill-color:#0F172A !important;}\n\n  /* PACK RECOMMENDATION */\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco {\n    margin-top: 12px; padding: 12px; background: #fff;\n    border: 1.5px solid var(--accent); border-radius: 12px;\n    transition: all 0.3s ease;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-label {\n    font-size: 10px; font-weight: 800; text-transform: uppercase;\n    letter-spacing: 0.08em; color: var(--accent); margin-bottom: 6px;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-name {\n    font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 2px;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-detail {\n    font-size: 12px; color: var(--muted); line-height: 1.4; margin-bottom: 6px;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-price {\n    display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-price .pr-now {\n    font-size: 22px; font-weight: 800; color: var(--text);\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-price .pr-was {\n    font-size: 13px; color: #94a3b8; text-decoration: line-through;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-price .pr-save {\n    font-size: 11px; font-weight: 700; color: #dc2626;\n    background: #fef2f2; padding: 2px 8px; border-radius: 6px;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-badge {\n    display: inline-block; font-size: 10px; font-weight: 800;\n    text-transform: uppercase; letter-spacing: 0.05em;\n    padding: 3px 10px; border-radius: 12px; margin-bottom: 6px;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-badge--best {\n    background: var(--accent); color: #fff;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-badge--eco {\n    background: #059669; color: #fff;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-badge--max {\n    background: #d97706; color: #fff;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-multi {\n    margin-top: 8px; padding-top: 8px; border-top: 1px solid #f0f1f3;\n    font-size: 12px; color: var(--muted); line-height: 1.4;\n  }\n  #calc-template--25831865057611__mold_calculator_h_qH63id .pack-reco-multi strong {\n    color: var(--text);\n  }\n</style>\n\n  <div class=\"container\">\n    <h2 class=\"headline\">Combien de modules Moisissure-CLEAN me faut-il ?</h2>\n\n    <div class=\"grid\">\n      <div class=\"left\">\n        <div class=\"group\">\n          <div class=\"label\">Longueur du mur concerné</div>\n          <div class=\"range-row\">\n            <input id=\"area-template--25831865057611__mold_calculator_h_qH63id\" type=\"range\" step=\"0.5\" value=\"3\" min=\"0.5\" max=\"10\" style=\"--fill: 26.31578947368421%;\">\n            <div class=\"pill\">\n              <span class=\"val\" id=\"areaValue-template--25831865057611__mold_calculator_h_qH63id\">3.0</span>\n              <span id=\"unitLabel-template--25831865057611__mold_calculator_h_qH63id\">m</span>\n              <div class=\"unit-toggle\" id=\"unitToggle-template--25831865057611__mold_calculator_h_qH63id\">\n                <button type=\"button\" data-unit=\"m\" class=\"is-active\">m</button>\n                <button type=\"button\" data-unit=\"ft\">ft</button>\n              </div>\n            </div>\n          </div>\n          <div class=\"scale\">\n            <span id=\"minLabel-template--25831865057611__mold_calculator_h_qH63id\">0.5 m</span>\n            <span id=\"maxLabel-template--25831865057611__mold_calculator_h_qH63id\">10.0 m</span>\n          </div>\n          <div class=\"note\">Déplacez le curseur pour régler la longueur du mur infesté.</div>\n        </div>\n\n        <div class=\"group\" style=\"margin-bottom:0;\">\n          <div class=\"label\">Degré de gravité de la moisissure</div>\n          <select id=\"sev-template--25831865057611__mold_calculator_h_qH63id\">\n            <option value=\"faible infestation de moisissure\" data-factor=\"1.5\" data-op=\"divide\">faible infestation de moisissure</option>\n            <option value=\"forte infestation de moisissure\" data-factor=\"1\" data-op=\"multiply\">forte infestation de moisissure</option>\n          </select>\n          <div class=\"note\"><p>Choisissez la gravité de l'infestation de moisissure.</p></div>\n        </div>\n      </div>\n\n      <div class=\"right\">\n        <div class=\"card\">\n          <h3>Modules requis</h3>\n          <div class=\"total\" id=\"total-template--25831865057611__mold_calculator_h_qH63id\">2</div>\n          <div class=\"muted\">Calcul basé sur la longueur du mur et la gravité.</div>\n\n          <div class=\"pack-reco\" id=\"packReco-template--25831865057611__mold_calculator_h_qH63id\">\n            <div class=\"pack-reco-label\">✦ Pack recommandé pour votre mur</div>\n            <div id=\"packBadge-template--25831865057611__mold_calculator_h_qH63id\"></div>\n            <div class=\"pack-reco-name\" id=\"packName-template--25831865057611__mold_calculator_h_qH63id\"></div>\n            <div class=\"pack-reco-detail\" id=\"packDetail-template--25831865057611__mold_calculator_h_qH63id\"></div>\n            <div class=\"pack-reco-price\" id=\"packPrice-template--25831865057611__mold_calculator_h_qH63id\"></div>\n            <div class=\"pack-reco-multi\" id=\"packMulti-template--25831865057611__mold_calculator_h_qH63id\" style=\"display:none;\"></div>\n          </div>\n\n          <a href=\"javascript:void(0);\" class=\"btn\" onclick=\"scrollToMoisissureBundles()\">\n            Voir les formules →\n          </a>\n\n          <div class=\"muted\" style=\"margin-top:8px;\">🚚 Livraison offerte · Satisfait ou remboursé 30j</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      var root   = document.getElementById('calc-template--25831865057611__mold_calculator_h_qH63id');\n      var range  = root.querySelector('#area-template--25831865057611__mold_calculator_h_qH63id');\n      var areaV  = root.querySelector('#areaValue-template--25831865057611__mold_calculator_h_qH63id');\n      var unitLb = root.querySelector('#unitLabel-template--25831865057611__mold_calculator_h_qH63id');\n      var unitTg = root.querySelector('#unitToggle-template--25831865057611__mold_calculator_h_qH63id');\n      var minLb  = root.querySelector('#minLabel-template--25831865057611__mold_calculator_h_qH63id');\n      var maxLb  = root.querySelector('#maxLabel-template--25831865057611__mold_calculator_h_qH63id');\n      var sevSel = root.querySelector('#sev-template--25831865057611__mold_calculator_h_qH63id');\n      var total  = root.querySelector('#total-template--25831865057611__mold_calculator_h_qH63id');\n\n      var packName   = root.querySelector('#packName-template--25831865057611__mold_calculator_h_qH63id');\n      var packDetail = root.querySelector('#packDetail-template--25831865057611__mold_calculator_h_qH63id');\n      var packPrice  = root.querySelector('#packPrice-template--25831865057611__mold_calculator_h_qH63id');\n      var packBadge  = root.querySelector('#packBadge-template--25831865057611__mold_calculator_h_qH63id');\n      var packMulti  = root.querySelector('#packMulti-template--25831865057611__mold_calculator_h_qH63id');\n\n      var FT_PER_M = 3.28084;\n      var MIN_M = 0.5;\n      var MAX_M = 10;\n      var currentUnit = 'm';\n\n      /* ===== PRICING ===== */\n      var UNIT_COMPARE = 128.70;  /* prix barré par unité */\n      var UNIT_PRICE   = 69.97;   /* prix Pack Maison par unité */\n\n      var packs = [\n        { name: 'Essentiel',    qty: 1, price: 79.90,  compare: 128.70, save: 48,  badge: 'eco',  badgeText: 'Découverte',      desc: '1 zone ciblée' },\n        { name: 'Pack Duo ⭐',  qty: 2, price: 149.90, compare: 248.40, save: 98,  badge: 'best', badgeText: 'N°1 des ventes',  desc: 'Pièce entière' },\n        { name: 'Pack Maison',  qty: 3, price: 209.90, compare: 348.30, save: 138, badge: 'max',  badgeText: 'Max. économies',  desc: 'Multi-pièces' }\n      ];\n\n      function toFt(m){ return m * FT_PER_M; }\n      function toM(ft){ return ft / FT_PER_M; }\n      function oneDec(x){ return (Math.round(x*10)/10).toFixed(1); }\n      function fmtPrice(p){ return p.toFixed(2).replace('.', ',') + ' €'; }\n\n      /* Arrondir au ,90 supérieur */\n      function roundTo90(p){\n        var base = Math.floor(p);\n        return base + 0.90;\n      }\n\n      function syncSliderBounds(areaMeters){\n        if(currentUnit === 'm'){\n          range.min = MIN_M; range.max = MAX_M; range.step = 0.5;\n          range.value = oneDec(areaMeters);\n          minLb.textContent = oneDec(MIN_M) + ' m';\n          maxLb.textContent = oneDec(MAX_M) + ' m';\n        } else {\n          var minFt = toFt(MIN_M), maxFt = toFt(MAX_M);\n          range.min = oneDec(minFt); range.max = oneDec(maxFt); range.step = 0.5;\n          range.value = oneDec(toFt(areaMeters));\n          minLb.textContent = oneDec(minFt) + ' ft';\n          maxLb.textContent = oneDec(maxFt) + ' ft';\n        }\n      }\n\n      function getAreaMetersFromSlider(){\n        var v = parseFloat(range.value);\n        return currentUnit === 'm' ? v : toM(v);\n      }\n\n      function updateToggleUI(){\n        unitLb.textContent = currentUnit;\n        var buttons = unitTg.querySelectorAll('button');\n        buttons.forEach(function(btn){\n          if(btn.dataset.unit === currentUnit) btn.classList.add('is-active');\n          else btn.classList.remove('is-active');\n        });\n      }\n\n      /* ===== PACK RECOMMENDATION ===== */\n      function updatePackReco(modules){\n        if(modules <= 0) modules = 1;\n\n        if(modules <= 3){\n          /* Tiers 1-3 : recommandation directe */\n          var pack = packs[modules - 1];\n          packBadge.innerHTML = '<span class=\"pack-reco-badge pack-reco-badge--' + pack.badge + '\">' + pack.badgeText + '</span>';\n          packName.textContent = pack.name;\n          packDetail.textContent = pack.desc + ' · Couvre jusqu\\'à ' + (modules * 1.5).toFixed(1).replace('.0','') + ' m';\n          packPrice.innerHTML =\n            '<span class=\"pr-now\">' + fmtPrice(pack.price) + '</span>' +\n            '<span class=\"pr-was\">' + fmtPrice(pack.compare) + '</span>' +\n            '<span class=\"pr-save\">Économisez ' + pack.save + ' €</span>';\n          packMulti.style.display = 'none';\n\n        } else {\n          /* 4+ modules : Pack Maison + unités supplémentaires */\n          var extra = modules - 3;\n          var rawPrice = 209.90 + (extra * UNIT_PRICE);\n          var price = roundTo90(rawPrice);\n          var compare = 348.30 + (extra * UNIT_COMPARE);\n          var save = Math.floor(compare - price);\n\n          packBadge.innerHTML = '<span class=\"pack-reco-badge pack-reco-badge--max\">Meilleure offre</span>';\n          packName.textContent = 'Pack Maison + ' + extra + ' panneau' + (extra > 1 ? 'x' : '');\n          packDetail.textContent = modules + ' panneaux · Couvre jusqu\\'à ' + (modules * 1.5).toFixed(1).replace('.0','') + ' m · ' + fmtPrice(price / modules) + '/panneau';\n          packPrice.innerHTML =\n            '<span class=\"pr-now\">' + fmtPrice(price) + '</span>' +\n            '<span class=\"pr-was\">' + fmtPrice(compare) + '</span>' +\n            '<span class=\"pr-save\">Économisez ' + save + ' €</span>';\n\n          packMulti.innerHTML =\n            '👉 Sélectionnez <strong>Pack Maison</strong> puis ajoutez <strong>' + extra + ' unité' + (extra > 1 ? 's' : '') + '</strong> supplémentaire' + (extra > 1 ? 's' : '');\n          packMulti.style.display = 'block';\n        }\n      }\n\n      function calc(){\n        var areaMeters = getAreaMetersFromSlider();\n        var display = currentUnit === 'm' ? areaMeters : toFt(areaMeters);\n        areaV.textContent = oneDec(display);\n        unitLb.textContent = currentUnit;\n\n        var opt = sevSel.selectedOptions[0];\n        var factor = parseFloat(opt ? opt.dataset.factor : '1');\n        var op = (opt ? opt.dataset.op : 'multiply').toLowerCase();\n\n        var result = (op === 'divide') ? (areaMeters / (factor || 1)) : (areaMeters * (factor || 1));\n        result = Math.ceil(result);\n        if(result < 1) result = 1;\n\n        total.textContent = result;\n\n        var min = parseFloat(range.min), max = parseFloat(range.max);\n        var pct = ((parseFloat(range.value) - min) / (max - min)) * 100;\n        range.style.setProperty('--fill', pct + '%');\n\n        updatePackReco(result);\n      }\n\n      range.addEventListener('input', calc);\n      sevSel.addEventListener('change', calc);\n      unitTg.addEventListener('click', function(e){\n        var btn = e.target.closest('button[data-unit]');\n        if(!btn) return;\n        var oldMeters = getAreaMetersFromSlider();\n        currentUnit = btn.dataset.unit;\n        updateToggleUI();\n        syncSliderBounds(oldMeters);\n        calc();\n      });\n\n      updateToggleUI();\n      syncSliderBounds(3);\n      calc();\n    })();\n\n    function scrollToMoisissureBundles() {\n      var calcSection = document.getElementById('calc-template--25831865057611__mold_calculator_h_qH63id');\n      var target = null;\n\n      var allElements = document.querySelectorAll('*');\n      for (var i = 0; i < allElements.length; i++) {\n        var el = allElements[i];\n        var cls = (el.className && typeof el.className === 'string') ? el.className.toLowerCase() : '';\n        var eid = (el.id || '').toLowerCase();\n        if (cls.indexOf('kaching') > -1 || eid.indexOf('kaching') > -1 ||\n            cls.indexOf('bundle') > -1 || eid.indexOf('bundle') > -1 ||\n            cls.indexOf('monbundle') > -1 || eid.indexOf('monbundle') > -1) {\n          if (calcSection && (el === calcSection || calcSection.contains(el))) continue;\n          if (el.offsetHeight < 50) continue;\n          target = el; break;\n        }\n      }\n\n      if (!target) {\n        var formSelectors = [\n          'form[action*=\"/cart/add\"]', 'form[action*=\"/cart\"]',\n          '.product-form', '.product-form__buttons',\n          '[data-product-form]', '.shopify-product-form',\n          '#AddToCartForm', '.product__info-container', '.product__info-wrapper'\n        ];\n        for (var j = 0; j < formSelectors.length; j++) {\n          var found = document.querySelector(formSelectors[j]);\n          if (found && found.offsetHeight > 0) {\n            if (!calcSection || found.getBoundingClientRect().top < calcSection.getBoundingClientRect().top) {\n              target = found; break;\n            }\n          }\n        }\n      }\n\n      if (!target) {\n        var allButtons = document.querySelectorAll('button, .btn, a.button, [type=\"submit\"]');\n        for (var k = 0; k < allButtons.length; k++) {\n          var txt = (allButtons[k].textContent || '').trim().toLowerCase();\n          if (txt.indexOf('commander') > -1 || txt.indexOf('ajouter') > -1 || txt.indexOf('add to cart') > -1) {\n            if (calcSection && calcSection.contains(allButtons[k])) continue;\n            target = allButtons[k]; break;\n          }\n        }\n      }\n\n      if (target) {\n        var offsetTop = target.getBoundingClientRect().top + window.pageYOffset - 100;\n        window.scrollTo({ top: Math.max(0, offsetTop), behavior: 'smooth' });\n      }\n    }\n  </script>\n</section>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_html_Wwz8yM": {
      "type": "custom-html",
      "disabled": true,
      "name": "Custom HTML",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "html": "<div id=\"shopify-section-etapes-installation\" class=\"shopify-section\">\n  <section class=\"moisissure-steps\" style=\"background: #FFFFFF;\">\n    <div class=\"moisissure-steps__inner page-width\">\n\n      <p class=\"moisissure-steps__kicker\">C'est aussi simple que ça :</p>\n      <h2 class=\"moisissure-steps__title\">Déballer, brancher &amp; vivre sans moisissure !</h2>\n\n      <div class=\"moisissure-steps__track\" role=\"region\" aria-label=\"Étapes d'installation\">\n\n        <article class=\"moisissure-steps__card\">\n          <div class=\"moisissure-steps__number\">01</div>\n          <div class=\"moisissure-steps__image-wrapper\">\n            <img src=\"//schimmel-dry.com/cdn/shop/files/Vorbereitung.png?v=1740197382&amp;width=500\" alt=\"Préparation\" class=\"moisissure-steps__image\">\n          </div>\n          <div class=\"moisissure-steps__card-body\">\n            <h3 class=\"moisissure-steps__pill\">Préparation</h3>\n            <p class=\"moisissure-steps__text\"><strong>Moisissure-CLEAN</strong> est prêt à l'emploi immédiatement. Vous pouvez essuyer la tache de moisissure avec un produit naturel en préparation.</p>\n            <div class=\"moisissure-steps__benefit\">\n              <svg viewbox=\"0 0 13 10\" width=\"13\" height=\"10\" aria-hidden=\"true\">\n                <path d=\"M12.66 1.14a.9.9 0 0 0-1.24 0L4.96 7.61 2.25 4.88A.9.9 0 0 0 .75 6.16l3.33 3.33a.9.9 0 0 0 1.28 0l7.36-7.36a.9.9 0 0 0 0-1.24Z\" fill=\"#00A4C1\"></path>\n              </svg>\n              <span>Sans préparation complexe</span>\n            </div>\n          </div>\n        </article>\n\n        <article class=\"moisissure-steps__card\">\n          <div class=\"moisissure-steps__number\">02</div>\n          <div class=\"moisissure-steps__image-wrapper\">\n            <img src=\"//schimmel-dry.com/cdn/shop/files/Befestigen.png?v=1758698033&amp;width=500\" alt=\"Fixer\" class=\"moisissure-steps__image\">\n          </div>\n          <div class=\"moisissure-steps__card-body\">\n            <h3 class=\"moisissure-steps__pill\">Fixer</h3>\n            <p class=\"moisissure-steps__text\">Placez les pieds de support <strong>devant le mur</strong> ou fixez <strong>directement au mur</strong> avec les chevilles et vis fournies.</p>\n            <div class=\"moisissure-steps__benefit\">\n              <svg viewbox=\"0 0 13 10\" width=\"13\" height=\"10\" aria-hidden=\"true\">\n                <path d=\"M12.66 1.14a.9.9 0 0 0-1.24 0L4.96 7.61 2.25 4.88A.9.9 0 0 0 .75 6.16l3.33 3.33a.9.9 0 0 0 1.28 0l7.36-7.36a.9.9 0 0 0 0-1.24Z\" fill=\"#00A4C1\"></path>\n              </svg>\n              <span>Installation en 2 minutes</span>\n            </div>\n          </div>\n        </article>\n\n        <article class=\"moisissure-steps__card\">\n          <div class=\"moisissure-steps__number\">03</div>\n          <div class=\"moisissure-steps__image-wrapper\">\n            <img src=\"//schimmel-dry.com/cdn/shop/files/Anstecken.png?v=1740197382&amp;width=500\" alt=\"Brancher\" class=\"moisissure-steps__image\">\n          </div>\n          <div class=\"moisissure-steps__card-body\">\n            <h3 class=\"moisissure-steps__pill\">Brancher</h3>\n            <p class=\"moisissure-steps__text\">Branchez et <strong>laissez fonctionner en continu.</strong> La durée de séchage varie de quelques semaines à plusieurs mois selon l'humidité.</p>\n            <div class=\"moisissure-steps__benefit\">\n              <svg viewbox=\"0 0 13 10\" width=\"13\" height=\"10\" aria-hidden=\"true\">\n                <path d=\"M12.66 1.14a.9.9 0 0 0-1.24 0L4.96 7.61 2.25 4.88A.9.9 0 0 0 .75 6.16l3.33 3.33a.9.9 0 0 0 1.28 0l7.36-7.36a.9.9 0 0 0 0-1.24Z\" fill=\"#00A4C1\"></path>\n              </svg>\n              <span>Fonctionnement automatique</span>\n            </div>\n          </div>\n        </article>\n\n        <article class=\"moisissure-steps__card\">\n          <div class=\"moisissure-steps__number\">04</div>\n          <div class=\"moisissure-steps__image-wrapper\">\n            <img src=\"//schimmel-dry.com/cdn/shop/files/gesunder-leben.png?v=1740197382&amp;width=500\" alt=\"Vie saine\" class=\"moisissure-steps__image\">\n          </div>\n          <div class=\"moisissure-steps__card-body\">\n            <h3 class=\"moisissure-steps__pill\">Vie Saine</h3>\n            <p class=\"moisissure-steps__text\">Une fois sec, vous êtes <strong>libéré des moisissures.</strong> Maintenez votre mur sec avec des temps réduits via une <strong>minuterie.</strong></p>\n            <div class=\"moisissure-steps__benefit\">\n              <svg viewbox=\"0 0 13 10\" width=\"13\" height=\"10\" aria-hidden=\"true\">\n                <path d=\"M12.66 1.14a.9.9 0 0 0-1.24 0L4.96 7.61 2.25 4.88A.9.9 0 0 0 .75 6.16l3.33 3.33a.9.9 0 0 0 1.28 0l7.36-7.36a.9.9 0 0 0 0-1.24Z\" fill=\"#00A4C1\"></path>\n              </svg>\n              <span>Protection durable</span>\n            </div>\n          </div>\n        </article>\n\n      </div>\n\n    </div>\n  </section>\n</div>\n\n<style>\n/* ═══════════════════════════════\n   4 ÉTAPES D'INSTALLATION - VERSION PLUS COURTE (HAUTEUR RÉDUITE)\n   ═══════════════════════════════ */\n.moisissure-steps {\n  --radius: 16px;\n  --pill-bg: #00A4C1;\n  --pill-text: #FFFFFF;\n  --body-text: #333333;\n  --accent: #00A4C1;\n  --number-color: rgba(0, 164, 193, 0.16);\n  padding: 36px 18px 44px; /* ↓ plus court */\n  background: #FFFFFF;\n}\n\n@media (max-width: 749px) {\n  .moisissure-steps {\n    padding: 28px 12px 34px; /* ↓ plus court */\n  }\n}\n\n.moisissure-steps__inner {\n  max-width: 1600px;\n  margin: 0 auto;\n  overflow: visible;\n}\n\n.moisissure-steps__kicker {\n  text-transform: none;\n  letter-spacing: 0.01em;\n  color: #666;\n  font-size: 15px; /* ↓ */\n  line-height: 1.25;\n  text-align: center;\n  margin: 0 0 8px; /* ↓ */\n  font-weight: 500;\n}\n\n.moisissure-steps__title {\n  text-align: center;\n  color: #00a4c1;\n  font-weight: 700;\n  font-size: 28px; /* ↓ */\n  line-height: 1.25;\n  margin: 0 0 26px; /* ↓ */\n}\n\n@media (max-width: 749px) {\n  .moisissure-steps__kicker { font-size: 13px; }\n  .moisissure-steps__title { font-size: 20px; margin-bottom: 18px; }\n}\n\n.moisissure-steps__track {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px; /* ↓ */\n  overflow: visible;\n}\n\n@media (max-width: 989px) {\n  .moisissure-steps__track {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n    gap: 14px; /* ↓ */\n  }\n}\n\n@media (max-width: 749px) {\n  .moisissure-steps__track {\n    display: flex;\n    overflow-x: auto;\n    overflow-y: visible;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    gap: 12px; /* ↓ */\n    padding-bottom: 6px; /* ↓ */\n    padding-left: 8px;\n    padding-right: 8px;\n    margin-left: -8px;\n    margin-right: -8px;\n    scroll-padding: 16px;\n  }\n  .moisissure-steps__track::-webkit-scrollbar { display: none; }\n}\n\n.moisissure-steps__card {\n  background: #FFFFFF;\n  border-radius: var(--radius);\n  position: relative;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  scroll-snap-align: center;\n  box-shadow: 0 3px 14px rgba(0, 164, 193, 0.10); /* ↓ */\n  border: 1px solid #E0F7FA;\n  padding: 18px 16px 18px; /* ↓ */\n}\n\n@media (max-width: 749px) {\n  .moisissure-steps__card {\n    flex: 0 0 82%;\n    padding: 16px 14px 16px; /* ↓ */\n  }\n}\n\n.moisissure-steps__number {\n  color: var(--number-color);\n  font-size: 46px; /* ↓ */\n  font-weight: 800;\n  line-height: 1;\n  text-align: center;\n  margin: 0 0 10px 0; /* ↓ */\n}\n\n@media (max-width: 749px) {\n  .moisissure-steps__number { font-size: 40px; margin-bottom: 10px; }\n}\n\n.moisissure-steps__image-wrapper {\n  width: 100%;\n  aspect-ratio: 1 / 1; /* ↓ moins haut que 1/1 */\n  overflow: hidden;\n  border-radius: 12px; /* ↓ */\n  background: #F5F5F5;\n  margin-bottom: 12px; /* ↓ */\n}\n\n.moisissure-steps__image {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  object-position: center;\n  display: block;\n}\n\n.moisissure-steps__card-body {\n  text-align: center;\n  width: 100%;\n}\n\n.moisissure-steps__pill {\n  display: inline-block;\n  background: var(--pill-bg);\n  color: var(--pill-text);\n  font-weight: 700;\n  font-size: 15px; /* ↓ */\n  line-height: 1.2;\n  border-radius: 10px;\n  padding: 8px 16px; /* ↓ */\n  margin: 0 auto 10px; /* ↓ */\n  text-transform: uppercase;\n  letter-spacing: 0.4px;\n  box-shadow: 0 2px 6px rgba(0, 164, 193, 0.18); /* ↓ */\n}\n\n.moisissure-steps__text {\n  max-width: 100%;\n  margin: 0 auto 10px; /* ↓ */\n  color: var(--body-text);\n  letter-spacing: 0.01em;\n  font-size: 13px; /* ↓ */\n  line-height: 1.45; /* ↓ */\n  padding: 0 2px;\n}\n\n.moisissure-steps__text strong {\n  font-weight: 700;\n  color: #000;\n}\n\n.moisissure-steps__benefit {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  color: var(--accent);\n  font-weight: 600;\n  font-size: 13px; /* ↓ */\n  line-height: 1.2;\n}\n</style>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_liquid_QGhXnE": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"mec-box\">\n  <p class=\"mec-text\">\n    Les ondes infrarouges pénètrent <strong>jusqu'à 3 cm</strong> dans le mur.\n    L'humidité s'évapore de l'intérieur vers l'extérieur.\n    En <strong>4-6 semaines</strong>, le mur est sec. Sans humidité = <strong>zéro moisissure</strong>.\n  </p>\n  <div class=\"mec-tags\">\n    <span class=\"mec-tag\">🏛️ Restauration de monuments</span>\n    <span class=\"mec-tag\">🧪 0 produit chimique</span>\n    <span class=\"mec-tag\">⚡ ~3€/mois</span>\n  </div>\n</div>\n\n<style>\n.mec-box{max-width:600px;margin:0 auto 16px;padding:14px;background:#F0FDFA;border:1px solid #99F6E4;border-radius:10px;text-align:center}\n.mec-text{font-size:13px;color:#333;line-height:1.6;margin:0 0 10px}\n.mec-text strong{color:#00A4C1;font-weight:700}\n.mec-tags{display:flex;flex-wrap:wrap;gap:6px;justify-content:center}\n.mec-tag{font-size:11px;color:#0D9488;font-weight:600;background:#CCFBF1;padding:4px 10px;border-radius:20px;white-space:nowrap}\n@media(min-width:750px){\n  .mec-box{padding:20px}\n  .mec-text{font-size:15px}\n  .mec-tag{font-size:12px}\n}\n</style>",
