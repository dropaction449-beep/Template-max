          "settings": {
            "liquid": "<style>\n  .lyora-expedition {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    background: #f5f0e8;\n    border: 1.5px dashed #c8d8c0;\n    border-radius: 12px;\n    padding: 20px;\n    max-width: 420px;\n    width: 100%;\n    box-sizing: border-box;\n  }\n\n  .lyora-expedition__title {\n    font-size: 13px;\n    font-weight: 800;\n    color: #1a3320;\n    text-align: center;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    margin-bottom: 12px;\n  }\n\n  .lyora-expedition__subtitle {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 13px;\n    color: #3a7d52;\n    font-weight: 600;\n    margin-bottom: 16px;\n  }\n\n  .lyora-expedition__subtitle svg {\n    width: 16px;\n    height: 16px;\n    flex-shrink: 0;\n    stroke: #3a7d52;\n    fill: none;\n  }\n\n  .lyora-expedition__rows {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n\n  .lyora-expedition__row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 10px 14px;\n    border-radius: 8px;\n    background: #fff;\n    font-size: 13px;\n  }\n\n  .lyora-expedition__row--muted {\n    background: #ece8e0;\n    opacity: 0.7;\n  }\n\n  .lyora-expedition__row--active {\n    background: #1a3320;\n  }\n\n  .lyora-expedition__date {\n    font-weight: 600;\n    color: #1a3320;\n  }\n\n  .lyora-expedition__row--active .lyora-expedition__date {\n    color: #f5f0e8;\n  }\n\n  .lyora-expedition__row--muted .lyora-expedition__date {\n    color: #888;\n  }\n\n  .lyora-expedition__status {\n    font-size: 12px;\n    font-weight: 700;\n    color: #888;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n\n  .lyora-expedition__row--active .lyora-expedition__status {\n    color: #f7c948;\n  }\n\n  .lyora-expedition__row--muted .lyora-expedition__status {\n    color: #aaa;\n  }\n</style>\n\n<div class=\"lyora-expedition\">\n  <p class=\"lyora-expedition__title\" id=\"lyora-next-title\">Nächster Versand : ...</p>\n\n  <div class=\"lyora-expedition__subtitle\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path>\n      <polyline points=\"22 4 12 14.01 9 11.01\"></polyline>\n    </svg>\n    Sichern Sie sich Ihres vor dem nächsten Ausverkauf\n  </div>\n\n  <div class=\"lyora-expedition__rows\" id=\"lyora-rows\"></div>\n</div>\n\n<script>\n(function() {\n  var MONTHS_DE = [\n    'Januar','Februar','März','April','Mai','Juni',\n    'Juli','August','September','Oktober','November','Dezember'\n  ];\n\n  // Intervalle entre chaque expédition (en jours)\n  var INTERVAL = 8;\n\n  function formatDate(d) {\n    return d.getDate() + '. ' + MONTHS_DE[d.getMonth()];\n  }\n\n  function formatShort(d) {\n    var dd = String(d.getDate()).padStart(2,'0');\n    var mm = String(d.getMonth()+1).padStart(2,'0');\n    return dd + '/' + mm;\n  }\n\n  function addDays(d, n) {\n    var r = new Date(d);\n    r.setDate(r.getDate() + n);\n    return r;\n  }\n\n  var today = new Date();\n  today.setHours(0,0,0,0);\n\n  // Calcule la prochaine date d'expédition à partir d'aujourd'hui\n  // Date de référence : 4 Mars 2026\n  var ref = new Date(2026, 2, 4); // mois 0-indexé\n  ref.setHours(0,0,0,0);\n\n  // Avance la ref jusqu'à trouver la prochaine date >= aujourd'hui\n  while (ref < today) {\n    ref = addDays(ref, INTERVAL);\n  }\n\n  var next = ref;\n  var prev = addDays(next, -INTERVAL);\n  var future = addDays(next, INTERVAL);\n\n  // Titre\n  document.getElementById('lyora-next-title').textContent =\n    'Nächster Versand : ' + formatShort(next);\n\n  // Rows\n  var rows = [\n    {\n      date: prev,\n      label: 'Ausverkauft',\n      cls: 'lyora-expedition__row--muted',\n      statusStyle: ''\n    },\n    {\n      date: next,\n      label: '70% reserviert',\n      cls: 'lyora-expedition__row--active',\n      statusStyle: ''\n    },\n    {\n      date: future,\n      label: 'In Produktion',\n      cls: '',\n      statusStyle: 'color:#3a7d52'\n    }\n  ];\n\n  var container = document.getElementById('lyora-rows');\n  rows.forEach(function(r) {\n    var div = document.createElement('div');\n    div.className = 'lyora-expedition__row ' + r.cls;\n\n    var dateSpan = document.createElement('span');\n    dateSpan.className = 'lyora-expedition__date';\n    dateSpan.textContent = formatDate(r.date);\n\n    var statusSpan = document.createElement('span');\n    statusSpan.className = 'lyora-expedition__status';\n    if (r.statusStyle) statusSpan.style.cssText = r.statusStyle;\n    statusSpan.textContent = r.label;\n\n    div.appendChild(dateSpan);\n    div.appendChild(statusSpan);\n    container.appendChild(div);\n  });\n})();\n</script>"
          }
        },
