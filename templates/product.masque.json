        "liquid": "<style>\n  .revs-section {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    background: #fff;\n    padding: 28px 0 24px;\n    width: 100%;\n    box-sizing: border-box;\n  }\n\n  .revs-header {\n    padding: 0 16px;\n    margin-bottom: 20px;\n  }\n\n  .revs-title {\n    font-size: 22px;\n    font-weight: 800;\n    color: #1a1200;\n    line-height: 1.25;\n    margin-bottom: 8px;\n  }\n\n  .revs-title em {\n    font-style: italic;\n    text-decoration: underline;\n  }\n\n  .revs-subtitle {\n    font-size: 13px;\n    color: #555;\n    line-height: 1.5;\n    margin: 0;\n  }\n\n  .revs-carousel {\n    width: 100%;\n    overflow: hidden;\n  }\n\n  .revs-track {\n    display: flex;\n    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n  }\n\n  .revs-slide {\n    flex: 0 0 100vw;\n    width: 100vw;\n    padding: 0 16px;\n    box-sizing: border-box;\n  }\n\n  .revs-img {\n    width: 100%;\n    border-radius: 12px;\n    display: block;\n    object-fit: cover;\n  }\n\n  .revs-review {\n    padding: 14px 0 0;\n  }\n\n  .revs-stars {\n    display: flex;\n    gap: 2px;\n    margin-bottom: 8px;\n  }\n\n  .revs-stars svg {\n    width: 14px;\n    height: 14px;\n  }\n\n  .revs-text {\n    font-size: 13px;\n    color: #222;\n    line-height: 1.65;\n    margin: 0 0 8px;\n  }\n\n  .revs-name {\n    font-size: 12px;\n    font-weight: 700;\n    color: #7a6a45;\n    margin: 0;\n  }\n\n  .revs-nav {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    margin-top: 18px;\n    padding: 0 16px;\n  }\n\n  .revs-btn {\n    width: 34px;\n    height: 34px;\n    border-radius: 50%;\n    border: 1.5px solid #ddd;\n    background: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    padding: 0;\n    flex-shrink: 0;\n  }\n\n  .revs-btn svg {\n    width: 14px;\n    height: 14px;\n    stroke: #555;\n    stroke-width: 2;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .revs-dots {\n    display: flex;\n    gap: 5px;\n    align-items: center;\n  }\n\n  .revs-dot {\n    height: 6px;\n    width: 6px;\n    border-radius: 3px;\n    background: #ddd;\n    cursor: pointer;\n    transition: width 0.25s, background 0.25s;\n  }\n\n  .revs-dot.active {\n    width: 18px;\n    background: #c8923a;\n  }\n</style>\n\n<div class=\"revs-section\">\n\n  <div class=\"revs-header\">\n    <h2 class=\"revs-title\">Sie haben <em>die Kontrolle</em> über<br>ihren Körper zurückgewonnen</h2>\n    <p class=\"revs-subtitle\">Tausende haben Parasiten, Giftstoffe und Blähungen mit DAWTOX beseitigt. Hier sind ihre Ergebnisse.</p>\n  </div>\n\n  <div class=\"revs-carousel\">\n    <div class=\"revs-track\" id=\"revs-track\">\n\n      <!-- Slide 1 — Marine L. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/78292887-c148-4e7a-bb77-8c26a131b520?width=820\" alt=\"Vorher Nachher Marine\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">Ich esse bio, treibe Sport, kümmere mich um mich. Warum also dieser aufgeblähte Bauch, der NIEMALS verschwand? Diese Kur hat mir die Augen geöffnet. In 3 Wochen hat sich mein Bauch buchstäblich entleert. Meine Zuckergier ist weg. Ich habe gemerkt, dass mein Körper im Überlebensmodus war — wegen Dingen, die ich nicht mal sehen konnte. Jetzt fühle ich mich leicht.</p>\n          <p class=\"revs-name\">Marina L., 31 Jahre</p>\n        </div>\n      </div>\n\n      <!-- Slide 2 — Julie T. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/6e8fd462-7683-426c-85d6-1e68c8a6e2ce?width=820\" alt=\"Vorher Nachher Julie\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">Jeden Morgen dasselbe: flacher Bauch beim Aufwachen, aufgebläht wie ein Ballon mittags. Unmöglich zu wissen, welche Hosengröße ich tragen würde. In 10 Tagen blieb mein Bauch den GANZEN Tag stabil. Kein Aufblähen mehr nach dem Essen. Keine Schmerzen mehr. Ich trage endlich, was ich will, wann ich will. Das verändert ein Leben.</p>\n          <p class=\"revs-name\">Julia T., 42 Jahre</p>\n        </div>\n      </div>\n\n      <!-- Slide 3 — Laurent P. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/404f0a64-5e76-47fa-84a7-ca8aa8533104?width=820\" alt=\"Vorher Nachher Laurent\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">Mit 51 war mein Gesicht aufgedunsen — ich sah 60 aus. Nach 30 Tagen Dawtox kamen meine Wangenknochen und meine Kieferlinie zurück. Mein Geschäftspartner fragte mich, ob ich Schönheitsoperationen hatte. -6 cm Taillenumfang, ich habe mein Gesicht von 42 Jahren zurück. Meine Tochter: \"Papa, du siehst aus wie auf den Fotos von meiner Kindheit.\"</p>\n          <p class=\"revs-name\">Laurent P., 51 Jahre</p>\n        </div>\n      </div>\n\n      <!-- Slide 4 — Sophie M. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/fd8f9f8a-3fc3-41ea-bd71-a1328f552f0c?width=820\" alt=\"Vorher Nachher Sophie\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">Ich habe über 200€ für Probiotika, Leber-Detox und diverse Nahrungsergänzungsmittel ausgegeben — nichts. Mein Gesicht blieb aufgedunsen, ich wirkte erschöpft trotz 8h Schlaf. In 3 Wochen mit dieser Kur fragte mich mein Mann, ob ich meine Gesichtscreme gewechselt hätte. Nein — ich habe endlich das eliminiert, was mich von innen aufblähte. Mein Spiegelbild gefällt mir wieder.</p>\n          <p class=\"revs-name\">Sophie M., 34 Jahre</p>\n        </div>\n      </div>\n\n      <!-- Slide 5 — Thomas M. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/71bb332c-4f59-4a5d-8fcf-3d6a128fafc1?width=820\" alt=\"Vorher Nachher Thomas\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">+14 kg in 3 Jahren Startup, erschöpft, aufgeblähter Bauch, täglich 3 Kaffees. Nach 30 Tagen Dawtox: sichtbare Bauchmuskeln — OHNE eine einzige Sportstunde. Taillenumfang: 98 cm → 86 cm (-12 cm). Eine Freundin: \"Was hast du gemacht?! Wo warst du?!\" Seit 4 Monaten im Abo. Beste Gesundheitsinvestition meines Lebens.</p>\n          <p class=\"revs-name\">Thomas M., 38 Jahre</p>\n        </div>\n      </div>\n\n      <!-- Slide 6 — Léa B. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/f1995720-2e4a-47ad-b8a7-8070d094aea9?width=820\" alt=\"Vorher Nachher Léa\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">Vorher: alle 2h Kaffee um durchzuhalten. Nach 4 Wochen: ich schaffe meine 12h-Schichten ohne zusammenzubrechen. Was mich am meisten überrascht hat? Meine Haut. Sie strahlt jetzt — dabei hatte ich immer einen fahlen Teint. Meine Kollegen fragen, was ich gemacht habe. Ich hätte das vor 2 Jahren ausprobieren sollen.</p>\n          <p class=\"revs-name\">Léa B., 29 Jahre</p>\n        </div>\n      </div>\n\n      <!-- Slide 7 — Clara R. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/f0c62af3-f4b1-4266-b6ac-57ee6b17b979?width=820\" alt=\"Vorher Nachher Clara\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">Ich bin 27 und hatte einen Bauch wie in der Schwangerschaft. Ärzte: \"Das ist Stress.\" Internet: \"Iss besser.\" Ich habe ALLES versucht. Diese Kur war das Einzige, das das eigentliche Problem anging: meine überlastete Leber + mein kaputtes Verdauungssystem. In 1 Monat: -3 kg \"Wassereinlagerungen\", Energie x10, und ich schlafe endlich gut. Wenn Sie noch zögern — hören Sie auf. Probieren Sie es.</p>\n          <p class=\"revs-name\">Clara R., 27 Jahre</p>\n        </div>\n      </div>\n\n      <!-- Slide 8 — Camille D. -->\n      <div class=\"revs-slide\">\n        <img class=\"revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/e5fdc216-0efb-455b-9c3b-3d6d5e4b324f?width=820\" alt=\"Vorher Nachher Camille\">\n        <div class=\"revs-review\">\n          <div class=\"revs-stars\">\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n          </div>\n          <p class=\"revs-text\">Mein Bauch war DAUERHAFT aufgebläht. Sogar morgens nüchtern. Ich mied enge Kleidung, schämte mich im Badeanzug. Nach nur 2 Wochen schloss sich meine Jeans mühelos. Nach 5 Wochen: -4 cm Taillenumfang. Kein Diät. Einfach mein Körper, der endlich normal funktioniert. Ich dachte nicht, dass das möglich wäre.</p>\n          <p class=\"revs-name\">Camille D., 38 Jahre</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"revs-nav\">\n    <button class=\"revs-btn\" onclick=\"revsMove(-1)\" aria-label=\"Zurück\">\n      <svg viewBox=\"0 0 24 24\"><polyline points=\"15 18 9 12 15 6\"></polyline></svg>\n    </button>\n    <div class=\"revs-dots\" id=\"revs-dots\">\n      <div class=\"revs-dot active\" onclick=\"revsGo(0)\"></div>\n      <div class=\"revs-dot\" onclick=\"revsGo(1)\"></div>\n      <div class=\"revs-dot\" onclick=\"revsGo(2)\"></div>\n      <div class=\"revs-dot\" onclick=\"revsGo(3)\"></div>\n      <div class=\"revs-dot\" onclick=\"revsGo(4)\"></div>\n      <div class=\"revs-dot\" onclick=\"revsGo(5)\"></div>\n      <div class=\"revs-dot\" onclick=\"revsGo(6)\"></div>\n      <div class=\"revs-dot\" onclick=\"revsGo(7)\"></div>\n    </div>\n    <button class=\"revs-btn\" onclick=\"revsMove(1)\" aria-label=\"Weiter\">\n      <svg viewBox=\"0 0 24 24\"><polyline points=\"9 18 15 12 9 6\"></polyline></svg>\n    </button>\n  </div>\n\n</div>\n\n<script>\n(function () {\n  var current = 0;\n  var total = 8;\n  var track = document.getElementById('revs-track');\n  var dots = document.querySelectorAll('.revs-dot');\n\n  function update() {\n    track.style.transform = 'translateX(-' + (current * 100) + 'vw)';\n    dots.forEach(function (d, i) {\n      d.classList.toggle('active', i === current);\n    });\n  }\n\n  window.revsMove = function (dir) {\n    current = (current + dir + total) % total;\n    update()