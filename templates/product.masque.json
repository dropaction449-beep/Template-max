        "liquid_twT9Tc": {
          "type": "liquid",
          "settings": {
            "liquid": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'DM Sans', sans-serif;\n    background: #f7f3ee;\n    width: 100%;\n    padding: 24px 0 20px;\n  }\n\n  .section-label {\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #9c8b78;\n    margin-bottom: 6px;\n    text-align: center;\n  }\n\n  .section-title {\n    font-family: 'DM Serif Display', serif;\n    font-size: 22px;\n    color: #2c2416;\n    text-align: center;\n    margin-bottom: 20px;\n    line-height: 1.3;\n    padding: 0 16px;\n  }\n\n  .section-title em {\n    font-style: italic;\n    color: #7a6a45;\n  }\n\n  /* Carousel */\n  .carousel {\n    width: 100%;\n    position: relative;\n  }\n\n  .track-outer {\n    width: 100%;\n    overflow: hidden;\n  }\n\n  .track {\n    display: flex;\n    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n    width: 100%;\n  }\n\n  .slide {\n    min-width: 100%;\n    width: 100%;\n    padding: 0 16px;\n  }\n\n  /* Card */\n  .card {\n    background: #fffdf9;\n    border-radius: 20px;\n    padding: 22px 20px 20px;\n    border: 1px solid #ede4d6;\n    box-shadow: 0 4px 24px rgba(90, 70, 40, 0.08);\n    width: 100%;\n  }\n\n  .card-top {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 14px;\n  }\n\n  .avatar-wrap {\n    position: relative;\n    flex-shrink: 0;\n  }\n\n  .avatar-wrap img {\n    width: 56px;\n    height: 56px;\n    border-radius: 50%;\n    object-fit: cover;\n    display: block;\n    border: 2px solid #e8ddd0;\n  }\n\n  .verified-badge {\n    position: absolute;\n    bottom: -2px;\n    right: -2px;\n    width: 18px;\n    height: 18px;\n    background: #5c8c5a;\n    border-radius: 50%;\n    border: 2px solid #fffdf9;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .verified-badge svg {\n    width: 9px;\n    height: 9px;\n    stroke: white;\n    stroke-width: 2.5;\n    fill: none;\n  }\n\n  .card-meta { flex: 1; }\n\n  .card-name {\n    font-size: 14px;\n    font-weight: 600;\n    color: #2c2416;\n    margin-bottom: 4px;\n  }\n\n  .stars { display: flex; gap: 2px; }\n  .stars svg { width: 12px; height: 12px; }\n\n  .quote-mark {\n    font-family: 'DM Serif Display', serif;\n    font-size: 48px;\n    color: #e8ddd0;\n    line-height: 0.6;\n    margin-bottom: 10px;\n    display: block;\n  }\n\n  .card-text {\n    font-size: 13px;\n    color: #4a3f30;\n    line-height: 1.65;\n  }\n\n  .card-text strong {\n    color: #2c2416;\n    font-weight: 600;\n  }\n\n  /* Nav */\n  .nav {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    margin-top: 16px;\n    padding: 0 16px;\n  }\n\n  .nav-btn {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    border: 1.5px solid #d4c8b8;\n    background: #fffdf9;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    transition: all 0.2s ease;\n    box-shadow: 0 2px 8px rgba(90,70,40,0.08);\n  }\n\n  .nav-btn:active {\n    background: #2c2416;\n    border-color: #2c2416;\n  }\n\n  .nav-btn:active svg { stroke: white; }\n\n  .nav-btn svg {\n    width: 15px;\n    height: 15px;\n    stroke: #7a6a55;\n    stroke-width: 2;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    transition: stroke 0.2s;\n  }\n\n  .dots {\n    display: flex;\n    gap: 6px;\n    align-items: center;\n  }\n\n  .dot {\n    height: 6px;\n    width: 6px;\n    border-radius: 3px;\n    background: #d4c8b8;\n    cursor: pointer;\n    transition: all 0.3s ease;\n  }\n\n  .dot.active {\n    width: 18px;\n    background: #7a6a45;\n  }\n</style>\n</head>\n<body>\n\n  <p class=\"section-label\">Kundenstimmen</p>\n  <h2 class=\"section-title\">Was unsere Kunden <em>wirklich</em> sagen</h2>\n\n  <div class=\"carousel\">\n    <div class=\"track-outer\">\n      <div class=\"track\" id=\"track\">\n\n        <div class=\"slide\">\n          <div class=\"card\">\n            <div class=\"card-top\">\n              <div class=\"avatar-wrap\">\n                <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/6a62bb52-a478-49dd-a2f7-e3a0e78eb8d1\" alt=\"Laurence B.\">\n                <div class=\"verified-badge\"><svg viewBox=\"0 0 12 12\"><polyline points=\"2 6 5 9 10 3\"></polyline></svg></div>\n              </div>\n              <div class=\"card-meta\">\n                <div class=\"card-name\">Laurence B., 47 Jahre</div>\n                <div class=\"stars\">\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#e8ddd0\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                </div>\n              </div>\n            </div>\n            <span class=\"quote-mark\">\"</span>\n            <p class=\"card-text\">Meine Leber war dauerhaft überlastet — ich fühlte mich schwer und müde. <strong>Nach 3 Wochen Dawtox hat sich alles verändert.</strong> Ich bin leichter, klarer im Kopf. Meine Ärztin war selbst überrascht, wie sehr meine Werte gesunken sind.</p>\n          </div>\n        </div>\n\n        <div class=\"slide\">\n          <div class=\"card\">\n            <div class=\"card-top\">\n              <div class=\"avatar-wrap\">\n                <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/1bda218f-a813-4b03-bf5a-06383664fbfd\" alt=\"Marc D.\">\n                <div class=\"verified-badge\"><svg viewBox=\"0 0 12 12\"><polyline points=\"2 6 5 9 10 3\"></polyline></svg></div>\n              </div>\n              <div class=\"card-meta\">\n                <div class=\"card-name\">Marc D., 38 Jahre</div>\n                <div class=\"stars\">\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                  <svg viewBox=\"0 0 16 16\" fill=\"#c8923a\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                </div>\n              </div>\n            </div>\n            <span class=\"quote-mark\">\"</span>\n            <p class=\"card-text\">Ich hatte alles versucht — ohne Ergebnis. <strong>Dawtox hat meine Verdauungsprobleme in 2 Wochen gelöst.</strong> Kein Blähgefühl mehr, kein Unbehagen. So einfach, so wirksam. Ich möchte es nicht mehr missen.</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"nav\">\n      <button class=\"nav-btn\" onclick=\"move(-1)\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"15 18 9 12 15 6\"></polyline></svg>\n      </button>\n      <div class=\"dots\">\n        <div class=\"dot active\" onclick=\"goTo(0)\"></div>\n        <div class=\"dot\" onclick=\"goTo(1)\"></div>\n      </div>\n      <button class=\"nav-btn\" onclick=\"move(1)\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"9 18 15 12 9 6\"></polyline></svg>\n      </button>\n    </div>\n  </div>\n\n  <script>\n    let current = 0;\n    const total = 2;\n    const track = document.getElementById('track');\n    const dots = document.querySelectorAll('.dot');\n\n    function update() {\n      track.style.transform = `translateX(-${current * 100}%)`;\n      dots.forEach((d, i) => d.classList.toggle('active', i === current));\n    }\n    function move(dir) { current = (current + dir + total) % total; update(); }\n    function goTo(i) { current = i; update(); }\n\n    let startX = 0;\n    track.addEventListener('touchstart', e => startX = e.touches[0].clientX, {passive: true});\n    track.addEventListener('touchend', e => {\n      const diff = startX - e.changedTouches[0].clientX;\n      if (Math.abs(diff) > 40) move(diff > 0 ? 1 : -1);\n    }, {passive: true});\n  </script>\n\n</body>\n</html>"
          }
