idden; /* masque débordement horizontal */\n    }\n    .reviews-slider-track {\n      display: flex;\n      transition: transform 0.4s ease;\n    }\n    .reviews-slide {\n      flex: 0 0 calc(100% / 1); \n      max-width: calc(100% / 1);\n      padding: 0.5rem;\n      box-sizing: border-box;\n    }\n\n    /* CARD */\n    .review-card {\n      background: #fff;\n      border: 1px solid #eee;\n      border-radius: 8px;\n      overflow: hidden;\n      display: flex;\n      flex-direction: column;\n    }\n    .review-card__images {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      position: relative;\n      border-bottom: 1px solid #eee;\n    }\n    .review-card__image-left,\n    .review-card__image-right {\n      position: relative;\n    }\n    .review-card__image-left img,\n    .review-card__image-right img {\n      width: 100%;\n      height: auto;\n      display: block;\n      object-fit: cover;\n    }\n    .review-badge-left,\n    .review-badge-right {\n      position: absolute;\n      top: 0.5rem;\n      padding: 0.3rem 0.6rem;\n      background-color: #fff;\n      font-size: 0.7rem;\n      font-weight: 600;\n      border-radius: 12px;\n    }\n    .review-badge-left {\n      left: 0.5rem;\n    }\n    .review-badge-right {\n      right: 0.5rem;\n    }\n\n    /* Contenu de la carte */\n    .review-card__content {\n      padding: 0.75rem 1rem;\n      display: flex;\n      flex-direction: column;\n      gap: 0.5rem;\n    }\n    .review-user-info {\n      display: flex;\n      align-items: center;\n      gap: 0.5rem;\n      font-weight: 600;\n    }\n    .review-user-flag {\n      width: 24px;\n      height: 24px;\n      object-fit: contain;\n      border-radius: 50%;\n    }\n    .review-rating-title {\n      display: flex;\n      flex-direction: column;\n      gap: 0.25rem;\n    }\n    .review-stars {\n      display: flex;\n      gap: 2px;\n    }\n    .review-title {\n      font-weight: 600;\n    }\n    .review-verified {\n      display: inline-flex;\n      align-items: center;\n      gap: 0.3rem;\n      font-size: 0.9rem;\n      color: #028763;\n      font-weight: 500;\n    }\n    .review-verified-badge {\n      width: 16px;\n      height: 16px;\n      object-fit: contain;\n    }\n    .review-text {\n      font-size: 0.9rem;\n      line-height: 1.4;\n    }\n\n    /* NAV (flèches + dots) */\n    .reviews-nav {\n      margin-top: 1rem;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      gap: 1rem;\n    }\n    .reviews-arrow {\n      background: #fff;\n      border: 1px solid #ddd;\n      border-radius: 50%;\n      width: 36px; \n      height: 36px;\n      display: flex;\n      align-items: center; \n      justify-content: center;\n      cursor: pointer;\n      font-size: 1.2rem;\n    }\n    .reviews-dots {\n      display: flex;\n      gap: 8px;\n    }\n    .reviews-dots button {\n      width: 10px;\n      height: 10px;\n      border-radius: 50%;\n      background-color: #ccc;\n      border: none;\n      cursor: pointer;\n      padding: 0;\n    }\n    .reviews-dots button.is-active {\n      background-color: #028763;\n    }\n\n    /* Desktop : 3 slides */\n    @media (min-width: 1000px) {\n      .reviews-slide {\n        flex: 0 0 calc(100% / 3);\n        max-width: calc(100% / 3);\n      }\n    }\n  </style>\n\n  <!-- SCRIPT -->\n  <script>\n    (function() {\n      const track = document.getElementById('reviews-slider-track-template--24940377080074__before_after_reviews_xF9bed');\n      const btnPrev = document.getElementById('reviews-arrow-prev-template--24940377080074__before_after_reviews_xF9bed');\n      const btnNext = document.getElementById('reviews-arrow-next-template--24940377080074__before_after_reviews_xF9bed');\n      const dotsContainer = document.getElementById('reviews-dots-template--24940377080074__before_after_reviews_xF9bed');\n      const slides = track.querySelectorAll('.reviews-slide');\n      const totalSlides = slides.length;\n\n      function getSlidesPerView() {\n        return window.innerWidth >= 1000 ? 3 : 1;\n      }\n\n      let currentIndex = 0;\n      let slidesPerView = getSlidesPerView();\n      let totalPages = Math.ceil(totalSlides / slidesPerView);\n      let dots = [];\n\n      // Créer un dot par \"page\"\n      function createDots() {\n        dotsContainer.innerHTML = '';\n        dots = [];\n        totalPages = Math.ceil(totalSlides / slidesPerView);\n        for (let i = 0; i < totalPages; i++) {\n          const dotBtn = document.createElement('button');\n          dotBtn.addEventListener('click', () => {\n            goToSlide(i * slidesPerView);\n          });\n          dotsContainer.appendChild(dotBtn);\n          dots.push(dotBtn);\n        }\n      }\n\n      function updateSlider() {\n        slidesPerView = getSlidesPerView();\n        createDots();\n\n        if (currentIndex >= totalSlides) {\n          currentIndex = totalSlides - slidesPerView;\n        }\n        if (currentIndex < 0) currentIndex = 0;\n\n        const slideWidth = track.querySelector('.reviews-slide').clientWidth;\n        const offset = slideWidth * currentIndex;\n        track.style.transform = `translateX(-${offset}px)`;\n\n        // Activer le dot correspondant\n        dots.forEach((dotBtn, idx) => {\n          dotBtn.classList.remove('is-active');\n          if (idx === Math.floor(currentIndex / slidesPerView)) {\n            dotBtn.classList.add('is-active');\n          }\n        });\n      }\n\n      function goToSlide(index) {\n        currentIndex = index;\n        updateSlider();\n      }\n\n      btnPrev.addEventListener('click', () => {\n        currentIndex -= slidesPerView;\n        updateSlider();\n      });\n      btnNext.addEventListener('click', () => {\n        currentIndex += slidesPerView;\n        updateSlider();\n      });\n      window.addEventListener('resize', () => {\n        updateSlider();\n      });\n\n      // Init\n      updateSlider();\n    })();\n  </script>\n\n  \n</section>\n</div>",
