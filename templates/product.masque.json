266-b6ac-57ee6b17b979?width=820\" alt=\"Vorher Nachher Clara\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            </div>\n            <p class=\"lyora-revs-text\">Ich bin 27 und hatte einen Bauch wie in der Schwangerschaft. Ärzte: \"Das ist Stress.\" Internet: \"Iss besser.\" Ich habe ALLES versucht. Diese Kur war das Einzige, das das eigentliche Problem anging: meine überlastete Leber + mein kaputtes Verdauungssystem. In 1 Monat: -3 kg \"Wassereinlagerungen\", Energie x10, und ich schlafe endlich gut. Wenn Sie noch zögern — hören Sie auf. Probieren Sie es.</p>\n            <p class=\"lyora-revs-name\">Clara R., 27 Jahre</p>\n          </div>\n        </div>\n      </div>\n\n      <!-- Slide 8 — Camille D. -->\n      <div class=\"lyora-revs-slide\">\n        <div class=\"lyora-revs-card\">\n          <img class=\"lyora-revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/e5fdc216-0efb-455b-9c3b-3d6d5e4b324f?width=820\" alt=\"Vorher Nachher Camille\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            </div>\n            <p class=\"lyora-revs-text\">Mein Bauch war DAUERHAFT aufgebläht. Sogar morgens nüchtern. Ich mied enge Kleidung, schämte mich im Badeanzug. Nach nur 2 Wochen schloss sich meine Jeans mühelos. Nach 5 Wochen: -4 cm Taillenumfang. Kein Diät. Einfach mein Körper, der endlich normal funktioniert. Ich dachte nicht, dass das möglich wäre.</p>\n            <p class=\"lyora-revs-name\">Camille D., 38 Jahre</p>\n          </div>\n        </div>\n      </div>\n\n\n    </div>\n  </div>\n\n  <div class=\"lyora-revs-nav\">\n    <button class=\"lyora-revs-btn\" onclick=\"lyoraRevsMove(-1)\" aria-label=\"Zurück\">\n      <svg viewBox=\"0 0 24 24\"><polyline points=\"15 18 9 12 15 6\"></polyline></svg>\n    </button>\n    <div class=\"lyora-revs-dots\" id=\"lyora-revs-dots\">\n      <div class=\"lyora-revs-dot active\" onclick=\"lyoraRevsGo(0)\"></div>\n      <div class=\"lyora-revs-dot\" onclick=\"lyoraRevsGo(1)\"></div>\n      <div class=\"lyora-revs-dot\" onclick=\"lyoraRevsGo(2)\"></div>\n      <div class=\"lyora-revs-dot\" onclick=\"lyoraRevsGo(3)\"></div>\n      <div class=\"lyora-revs-dot\" onclick=\"lyoraRevsGo(4)\"></div>\n      <div class=\"lyora-revs-dot\" onclick=\"lyoraRevsGo(5)\"></div>\n      <div class=\"lyora-revs-dot\" onclick=\"lyoraRevsGo(6)\"></div>\n      <div class=\"lyora-revs-dot\" onclick=\"lyoraRevsGo(7)\"></div>\n    </div>\n    <button class=\"lyora-revs-btn\" onclick=\"lyoraRevsMove(1)\" aria-label=\"Weiter\">\n      <svg viewBox=\"0 0 24 24\"><polyline points=\"9 18 15 12 9 6\"><