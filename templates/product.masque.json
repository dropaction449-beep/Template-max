            "liquid": "<style>\n  /* Conteneur principal optimisé pour mobile */\n  .shipping-card {\n    border: 1.5px dashed #333;\n    border-radius: 12px;\n    padding: 15px;\n    /* Prend 95% de la largeur sur mobile, max 450px sur ordinateur */\n    width: 95%;\n    max-width: 450px; \n    margin: 10px auto; /* Centre le bloc */\n    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\n    background-color: #fff;\n    box-sizing: border-box; /* Important pour le calcul de la largeur */\n  }\n\n  /* Titre principal */\n  .shipping-header {\n    text-align: center;\n    text-transform: uppercase;\n    font-weight: bold;\n    font-size: 16px; /* Légèrement réduit pour mobile */\n    color: #1a2b23;\n    margin-bottom: 12px;\n    letter-spacing: 0.5px;\n  }\n\n  /* Ligne de sous-titre avec icône */\n  .shipping-subtitle {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n    font-size: 13px;\n    color: #1a2b23;\n    margin-bottom: 18px;\n    line-height: 1.3;\n  }\n  \n  .shipping-subtitle svg {\n    flex-shrink: 0; /* Empêche l'icône de s'écraser */\n    width: 18px;\n    height: 18px;\n  }\n\n  /* Conteneur des lignes de statut */\n  .status-list {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n\n  /* Style des lignes */\n  .status-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 10px 15px;\n    border-radius: 10px;\n    font-size: 14px;\n    background-color: #f4f4f4;\n    color: #888;\n  }\n\n  /* Ligne active (1. März) */\n  .status-row.active {\n    background-color: #fdf6ee;\n    border: 1.5px solid #1a2b23;\n    color: #1a2b23;\n    font-weight: 500;\n  }\n\n  .status-label {\n    font-weight: 500;\n  }\n\n  .status-value {\n    text-transform: uppercase;\n    font-size: 11px;\n    font-weight: bold;\n    letter-spacing: 0.3px;\n    text-align: right;\n  }\n</style>\n\n<div class=\"shipping-card\">\n  <div class=\"shipping-header\">NÄCHSTER VERSAND: 01.03.</div>\n  \n  <div class=\"shipping-subtitle\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path><polyline points=\"22 4 12 14.01 9 11.01\"></polyline></svg>\n    <span>Reservieren Sie Ihres, bevor es wieder ausverkauft ist</span>\n  </div>\n\n  <div class=\"status-list\">\n    <div class=\"status-row\">\n      <span class=\"status-label\">18. Februar</span>\n      <span class=\"status-value\">AUSVERKAUFT</span>\n    </div>\n\n    <div class=\"status-row active\">\n      <span class=\"status-label\">1. März</span>\n      <span class=\"status-value\">60% RESERVIERT</span>\n    </div>\n\n    <div class=\"status-row\">\n      <span class=\"status-label\">10. März</span>\n      <span class=\"status-value\">IN PRODUKTION</span>\n    </div>\n  </div>\n</div>"
