        "remove_horizontal_spacing": true,
        "liquid": "<div id=\"vorher-nachher-section\">\n<style>\n  .lyora-revs-section {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    background: #fff5ef;\n    padding: 32px 0 28px;\n    width: 100%;\n    box-sizing: border-box;\n  }\n\n  .lyora-revs-header {\n    padding: 0 20px;\n    margin-bottom: 24px;\n    text-align: center;\n  }\n\n  .lyora-revs-title {\n    font-size: 22px;\n    font-weight: 800;\n    color: #1a1200;\n    line-height: 1.3;\n    margin-bottom: 10px;\n  }\n\n  .lyora-revs-title em {\n    font-style: italic;\n    text-decoration: underline;\n    text-decoration-thickness: 2px;\n    text-underline-offset: 3px;\n  }\n\n  .lyora-revs-subtitle {\n    font-size: 13px;\n    color: #666;\n    line-height: 1.5;\n    margin: 0;\n    max-width: 500px;\n    margin: 0 auto;\n  }\n\n  .lyora-revs-carousel {\n    width: 100%;\n    overflow: hidden;\n  }\n\n  .lyora-revs-track {\n    display: flex;\n  }\n\n  .lyora-revs-slide {\n    flex: 0 0 100vw;\n    width: 100vw;\n    padding: 0 20px;\n    box-sizing: border-box;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n  }\n\n  .lyora-revs-card {\n    background: white;\n    border: 2px solid #111;\n    border-radius: 16px;\n    overflow: hidden;\n    max-width: 340px;\n    width: 100%;\n    box-shadow: 0 2px 0 #111;\n    display: flex;\n    flex-direction: column;\n    height: 520px;\n  }\n\n  .lyora-revs-img {\n    width: 100%;\n    height: 280px;\n    display: block;\n    object-fit: cover;\n    flex-shrink: 0;\n  }\n\n  .lyora-revs-review {\n    padding: 18px 16px 20px;\n    background: #fff5ef;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    flex: 1;\n    text-align: center;\n  }\n\n  .lyora-revs-stars {\n    display: flex;\n    gap: 2px;\n    margin-bottom: 12px;\n    justify-content: center;\n  }\n\n  .lyora-revs-stars svg {\n    width: 16px;\n    height: 16px;\n  }\n\n  .lyora-revs-text {\n    font-size: 12px;\n    color: #333;\n    line-height: 1.6;\n    margin: 0 0 12px;\n    text-align: center;\n  }\n\n  .lyora-revs-name {\n    font-size: 12px;\n    font-weight: 700;\n    color: #1a1200;\n    margin: 0;\n    text-align: center;\n    font-style: italic;\n  }\n\n  .lyora-revs-nav {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    margin-top: 20px;\n    padding: 0 20px;\n  }\n\n  .lyora-revs-btn {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    border: 2px solid #111;\n    background: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    padding: 0;\n    flex-shrink: 0;\n  }\n\n  .lyora-revs-btn svg {\n    width: 14px;\n    height: 14px;\n    stroke: #111;\n    stroke-width: 2;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .lyora-revs-dots {\n    display: flex;\n    gap: 5px;\n    align-items: center;\n  }\n\n  .lyora-revs-dot {\n    height: 6px;\n    width: 6px;\n    border-radius: 3px;\n    background: #ddd;\n    cursor: pointer;\n    border: 1px solid #ccc;\n  }\n\n  .lyora-revs-dot.active {\n    width: 20px;\n    background: #111;\n    border-color: #111;\n  }\n\n  /* Responsive */\n  @media (max-width: 768px) {\n    .lyora-revs-section {\n      padding: 28px 0 24px;\n    }\n\n    .lyora-revs-title {\n      font-size: 20px;\n    }\n\n    .lyora-revs-subtitle {\n      font-size: 12px;\n    }\n\n    .lyora-revs-slide {\n      padding: 0 16px;\n    }\n\n    .lyora-revs-card {\n      max-width: 320px;\n      height: 500px;\n    }\n\n    .lyora-revs-img {\n      height: 260px;\n    }\n\n    .lyora-revs-text {\n      font-size: 11px;\n    }\n\n    .lyora-revs-name {\n      font-size: 11px;\n    }\n  }\n</style>\n\n<div class=\"lyora-revs-section\">\n\n  <div class=\"lyora-revs-header\">\n    <h2 class=\"lyora-revs-title\">Sie haben <em>die Kontrolle</em> über<br>ihren Körper zurückgewonnen</h2>\n    <p class=\"lyora-revs-subtitle\">Tausende haben Parasiten, Giftstoffe und Blähungen mit LYORA beseitigt. Hier sind ihre Ergebnisse.</p>\n  </div>\n\n  <div class=\"lyora-revs-carousel\">\n    <div class=\"lyora-revs-track\" id=\"lyora-revs-track\">\n\n      <!-- Slide 1 — Marina L. -->\n      <div class=\"lyora-revs-slide\">\n        <div class=\"lyora-revs-card\">\n          <img class=\"lyora-revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/78292887-c148-4e7a-bb77-8c26a131b520?width=820\" alt=\"Vorher Nachher Marina\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            </div>\n            <p class=\"lyora-revs-text\">Ich esse bio, treibe Sport, kümmere mich um mich. Warum also dieser aufgeblähte Bauch, der NIEMALS verschwand? Diese Kur hat mir die Augen geöffnet. In 3 Wochen hat sich mein Bauch buchstäblich entleert. Meine Zuckergier ist weg. Ich habe gemerkt, dass mein Körper im Überlebensmodus war — wegen Dingen, die ich nicht mal sehen konnte. Jetzt fühle ich mich leicht.</p>\n            <p class=\"lyora-revs-name\">Marina L., 31 Jahre</p>\n          </div>\n        </div>\n      </div>\n\n      <!-- Slide 2 — Julia T. -->\n      <div class=\"lyora-revs-slide\">\n        <div class=\"lyora-revs-card\">\n          <img class=\"lyora-revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/6e8fd462-7683-426c-85d6-1e68c8a6e2ce?width=820\" alt=\"Vorher Nachher Julia\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            </div>\n            <p class=\"lyora-revs-text\">Jeden Morgen dasselbe: flacher Bauch beim Aufwachen, aufgebläht wie ein Ballon mittags. Unmöglich zu wissen, welche Hosengröße ich tragen würde. In 10 Tagen blieb mein Bauch den GANZEN Tag stabil. Kein Aufblähen mehr nach dem Essen. Keine Schmerzen mehr. Ich trage endlich, was ich will, wann ich will. Das verändert ein Leben.</p>\n            <p class=\"lyora-revs-name\">Julia T., 42 Jahre</p>\n          </div>\n        </div>\n      </div>\n\n      <!-- Slide 3 — Laurent P. -->\n      <div class=\"lyora-revs-slide\">\n        <div class=\"lyora-revs-card\">\n          <img class=\"lyora-revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/404f0a64-5e76-47fa-84a7-ca8aa8533104?width=820\" alt=\"Vorher Nachher Laurent\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            </div>\n            <p class=\"lyora-revs-text\">Mit 51 war mein Gesicht aufgedunsen — ich sah 60 aus. Nach 30 Tagen LYORA kamen meine Wangenknochen und meine Kieferlinie zurück. Mein Geschäftspartner fragte mich, ob ich Schönheitsoperationen hatte. -6 cm Taillenumfang, ich habe mein Gesicht von 42 Jahren zurück. Meine Tochter: \"Papa, du siehst aus wie auf den Fotos von meiner Kindheit.\"</p>\n            <p class=\"lyora-revs-name\">Laurent P., 51 Jahre</p>\n          </div>\n        </div>\n      </div>\n\n      <!-- Slide 4 — Sophie M. -->\n      <div class=\"lyora-revs-slide\">\n        <div class=\"lyora-revs-card\">\n          <img class=\"lyora-revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/fd8f9f8a-3fc3-41ea-bd71-a1328f552f0c?width=820\" alt=\"Vorher Nachher Sophie\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            </div>\n            <p class=\"lyora-revs-text\">Ich habe über 200€ für Probiotika, Leber-Detox und diverse Nahrungsergänzungsmittel ausgegeben — nichts. Mein Gesicht blieb aufgedunsen, ich wirkte erschöpft trotz 8h Schlaf. In 3 Wochen mit dieser Kur fragte mich mein Mann, ob ich meine Gesichtscreme gewechselt hätte. Nein — ich habe endlich das eliminiert, was mich von innen aufblähte. Mein Spiegelbild gefällt mir wieder.</p>\n            <p class=\"lyora-revs-name\">Sophie M., 34 Jahre</p>\n          </div>\n        </div>\n      </div>\n\n      <!-- Slide 5 — Thomas M. -->\n      <div class=\"lyora-revs-slide\">\n        <div class=\"lyora-revs-card\">\n          <img class=\"lyora-revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/71bb332c-4f59-4a5d-8fcf-3d6a128fafc1?width=820\" alt=\"Vorher Nachher Thomas\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n            </div>\n            <p class=\"lyora-revs-text\">+14 kg in 3 Jahren Startup, erschöpft, aufgeblähter Bauch, täglich 3 Kaffees. Nach 30 Tagen LYORA: sichtbare Bauchmuskeln — OHNE eine einzige Sportstunde. Taillenumfang: 98 cm → 86 cm (-12 cm). Eine Freundin: \"Was hast du gemacht?! Wo warst du?!\" Seit 4 Monaten im Abo. Beste Gesundheitsinvestition meines Lebens.</p>\n            <p class=\"lyora-revs-name\">Thomas M., 38 Jahre</p>\n          </div>\n        </div>\n      </div>\n\n      <!-- Slide 6 — Léa B. -->\n      <div class=\"lyora-revs-slide\">\n        <div class=\"lyora-revs-card\">\n          <img class=\"lyora-revs-img\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/f1995720-2e4a-47ad-b8a7-8070d094aea9?width=820\" alt=\"Vorher Nachher Léa\">\n          <div class=\"lyora-revs-review\">\n            <div class=\"lyora-revs-stars\">\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              <svg viewBox=\"0 0 16 16\" fill=\"#FFC600\"><path d