            "liquid": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n  *{box-sizing:border-box;margin:0;padding:0}\n  body{\n    font-family:'DM Sans',system-ui,-apple-system,Segoe UI,sans-serif;\n    background:#ffffff;\n    padding:14px 0 10px;\n  }\n\n  /* Optional top micro-badges (comme sur ton image) */\n  .top-badges{\n    width:min(320px, 80vw);\n    margin:0 auto 8px;\n    font-size:10px;\n}\n  .top-badges span{display:inline-flex;gap:6px;align-items:center;opacity:.9}\n\n  /* Carousel wrapper */\n.wrap{\n    width:min(320px, 80vw);\n    margin:0 auto;\n    position:relative;\n}\n\n  .track-outer{overflow:hidden}\n  .track{\n    display:flex;\n    transition:transform .35s ease;\n    will-change:transform;\n  }\n  .slide{min-width:100%}\n\n  /* Card (style téléphone, comme ton screenshot) */\n.card{\n    background:#fff;\n    border:1px solid #d9e3d9;\n    border-radius:14px;\n    padding:10px 10px 8px;\n    box-shadow:0 6px 18px rgba(0,0,0,.06);\n}\n\n  .row{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    margin-bottom:10px;\n  }\n\n  .avatar{\n    width:32px;height:32px;border-radius:50%;\n    object-fit:cover;flex:0 0 auto;\n    border:1px solid #e6efe6;\n}\n\n  .meta{flex:1;min-width:0}\n  .name{\n    font-size:12px;\n    font-weight:700;\n    color:#1f3b1f;\n    line-height:1.1;\n    margin-bottom:3px;\n    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\n}\n\n  .stars{\n    display:flex;\n    gap:2px;\n    margin-left:auto;\n  }\n  .stars svg{width:11px;height:11px}\n\n  .text{\n    font-size:11px;\n    line-height:1.4;\n    color:#2b2b2b;\n    font-style:italic;\n}\n\n  /* Arrows like screenshot */\n.nav-btn{\n    position:absolute;\n    top:50%;\n    transform:translateY(-50%);\n    width:34px;height:34px;border-radius:999px;\n    border:1px solid #d9e3d9;\n    background:#fff;\n    display:flex;align-items:center;justify-content:center;\n    box-shadow:0 4px 12px rgba(0,0,0,.08);\n    cursor:pointer;\n    user-select:none;\n    z-index:10;\n    -webkit-tap-highlight-color:transparent;\n    touch-action:manipulation;\n}\n  .nav-btn svg{width:16px;height:16px;stroke:#2b2b2b;stroke-width:2;fill:none}\n  .nav-left{left:-12px}\n  .nav-right{right:-12px}\n\n  /* Dots small */\n  .dots{\n    display:flex;justify-content:center;gap:6px;\n    margin-top:10px;\n  }\n  .dot{\n    width:6px;height:6px;border-radius:999px;\n    background:#cfd9cf;\n    transition:all .25s ease;\n    cursor:pointer;\n  }\n  .dot.active{width:18px;background:#1f3b1f}\n\n  @media (max-width:360px){\n    .nav-left{left:-8px}\n    .nav-right{right:-8px}\n  }\n</style>\n</head>\n<body>\n\n  <div class=\"wrap\">\n    <button class=\"nav-btn nav-left\" onclick=\"move(-1)\" aria-label=\"Zurück\">\n      <svg viewBox=\"0 0 24 24\"><polyline points=\"15 18 9 12 15 6\"/></svg>\n    </button>\n\n    <div class=\"track-outer\">\n      <div class=\"track\" id=\"track\">\n\n        <!-- Slide 1 -->\n        <div class=\"slide\">\n          <div class=\"card\">\n            <div class=\"row\">\n              <img class=\"avatar\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/6a62bb52-a478-49dd-a2f7-e3a0e78eb8d1\" alt=\"Laurence B.\">\n              <div class=\"meta\">\n                <div class=\"name\">Laurence B., 47 Jahre</div>\n              </div>\n              <div class=\"stars\" aria-label=\"4 von 5 Sternen\">\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#e9ecef\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              </div>\n            </div>\n            <p class=\"text\">„Meine Leber war müde, ich hatte ständig ein schweres Gefühl. <strong>Lyora hat mich wieder in Schwung gebracht.</strong> Ich fühle mich leichter und insgesamt fitter. Meine Werte sind sogar gesunken.“</p>\n          </div>\n        </div>\n\n        <!-- Slide 2 -->\n        <div class=\"slide\">\n          <div class=\"card\">\n            <div class=\"row\">\n              <img class=\"avatar\" src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/1bda218f-a813-4b03-bf5a-06383664fbfd\" alt=\"Marc D.\">\n              <div class=\"meta\">\n                <div class=\"name\">Marc D., 38 Jahre</div>\n              </div>\n              <div class=\"stars\" aria-label=\"5 von 5 Sternen\">\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n                <svg viewBox=\"0 0 16 16\" fill=\"#f5b400\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/></svg>\n              </div>\n            </div>\n            <p class=\"text\">„Ich hatte alles versucht — ohne Erfolg. <strong>Lyora hat meine Verdauung in 2 Wochen beruhigt.</strong> Kein Blähgefühl mehr, kein Unwohlsein. Einfach und wirksam.“</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <button class=\"nav-btn nav-right\" onclick=\"move(1)\" aria-label=\"Weiter\">\n      <svg viewBox=\"0 0 24 24\"><polyline points=\"9 18 15 12 9 6\"/></svg>\n    </button>\n\n    <div class=\"dots\">\n      <div class=\"dot active\" onclick=\"goTo(0)\"></div>\n      <div class=\"dot\" onclick=\"goTo(1)\"></div>\n    </div>\n  </div>\n\n<script>\n  let current = 0;\n  const total = 2;\n  const track = document.getElementById('track');\n  const dots = document.querySelectorAll('.dot');\n\n  function update(){\n    track.style.transform = `translateX(-${current * 100}%)`;\n    dots.forEach((d,i)=>d.classList.toggle('active', i===current));\n  }\n  function move(dir){ current = (current + dir + total) % total; update(); }\n  function goTo(i){ current = i; update(); }\n\n  // Swipe mobile\n  let startX = 0;\n  track.addEventListener('touchstart', e => startX = e.touches[0].clientX, {passive:true});\n  track.addEventListener('touchend', e => {\n    const diff = startX - e.changedTouches[0].clientX;\n    if (Math.abs(diff) > 40) move(diff > 0 ? 1 : -1);\n  }, {passive:true});\n</script>\n\n</body>\n</html>"
