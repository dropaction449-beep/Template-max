        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "html": "<style>\n  .lyora-reviews-section {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    background: #fff5ef;\n    padding: 40px 20px;\n    max-width: 100%;\n  }\n\n  .lyora-reviews-container {\n    max-width: 800px;\n    margin: 0 auto;\n  }\n\n  .lyora-reviews-header {\n    text-align: center;\n    margin-bottom: 32px;\n  }\n\n  .lyora-reviews-title {\n    font-size: 26px;\n    font-weight: 800;\n    color: #1a1200;\n    margin-bottom: 16px;\n  }\n\n  .lyora-reviews-summary {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    margin-bottom: 8px;\n  }\n\n  .lyora-reviews-stars {\n    display: flex;\n    gap: 3px;\n  }\n\n  .lyora-reviews-stars svg {\n    width: 20px;\n    height: 20px;\n  }\n\n  .lyora-reviews-rating {\n    font-size: 18px;\n    font-weight: 700;\n    color: #1a1200;\n  }\n\n  .lyora-reviews-count {\n    font-size: 14px;\n    color: #666;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .lyora-verified-badge {\n    width: 16px;\n    height: 16px;\n  }\n\n  /* Histogram */\n  .lyora-histogram {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    margin-bottom: 24px;\n    padding: 20px;\n    background: white;\n    border: 2px solid #111;\n    border-radius: 12px;\n  }\n\n  .lyora-histogram-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n\n  .lyora-histogram-stars {\n    display: flex;\n    gap: 2px;\n    min-width: 90px;\n  }\n\n  .lyora-histogram-stars svg {\n    width: 14px;\n    height: 14px;\n  }\n\n  .lyora-histogram-bar {\n    flex: 1;\n    height: 8px;\n    background: #e5e5e5;\n    border-radius: 4px;\n    overflow: hidden;\n  }\n\n  .lyora-histogram-bar-fill {\n    height: 100%;\n    background: #f7c948;\n    border-radius: 4px;\n  }\n\n  .lyora-histogram-count {\n    min-width: 40px;\n    text-align: right;\n    font-size: 13px;\n    font-weight: 600;\n    color: #1a1200;\n  }\n\n  /* Sort Dropdown */\n  .lyora-sort-wrapper {\n    margin-bottom: 24px;\n  }\n\n  .lyora-sort-select {\n    width: 100%;\n    max-width: 250px;\n    padding: 10px 14px;\n    border: 2px solid #111;\n    border-radius: 8px;\n    background: white;\n    font-size: 13px;\n    font-weight: 600;\n    color: #1a1200;\n    cursor: pointer;\n  }\n\n  /* Review Item */\n  .lyora-review-item {\n    background: white;\n    border: 2px solid #111;\n    border-radius: 12px;\n    padding: 20px;\n    margin-bottom: 16px;\n  }\n\n  .lyora-review-header {\n    display: flex;\n    align-items: flex-start;\n    gap: 12px;\n    margin-bottom: 12px;\n  }\n\n  .lyora-review-avatar {\n    width: 40px;\n    height: 40px;\n    border-radius: 50%;\n    background: #f7c948;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 700;\n    color: #111;\n    flex-shrink: 0;\n  }\n\n  .lyora-review-meta {\n    flex: 1;\n  }\n\n  .lyora-review-author {\n    font-size: 14px;\n    font-weight: 700;\n    color: #1a1200;\n    margin-bottom: 4px;\n  }\n\n  .lyora-review-verified {\n    display: inline-flex;\n    align-items: center;\n    gap: 4px;\n    font-size: 11px;\n    color: #666;\n    margin-left: 8px;\n  }\n\n  .lyora-review-rating-row {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 4px;\n  }\n\n  .lyora-review-stars {\n    display: flex;\n    gap: 2px;\n  }\n\n  .lyora-review-stars svg {\n    width: 14px;\n    height: 14px;\n  }\n\n  .lyora-review-date {\n    font-size: 12px;\n    color: #888;\n  }\n\n  .lyora-review-body {\n    font-size: 14px;\n    line-height: 1.6;\n    color: #333;\n    margin-bottom: 12px;\n  }\n\n  .lyora-review-badge {\n    display: inline-flex;\n    align-items: center;\n    padding: 6px 10px;\n    border: 1px solid #e5e5e5;\n    border-radius: 6px;\n    font-size: 11px;\n    color: #666;\n  }\n\n  /* Pagination */\n  .lyora-pagination {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 8px;\n    margin-top: 32px;\n  }\n\n  .lyora-page-btn {\n    min-width: 36px;\n    height: 36px;\n    padding: 0 12px;\n    border: 2px solid #111;\n    border-radius: 8px;\n    background: white;\n    font-size: 13px;\n    font-weight: 600;\n    color: #111;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .lyora-page-btn.active {\n    background: #f7c948;\n  }\n\n  /* Responsive */\n  @media (max-width: 768px) {\n    .lyora-reviews-section {\n      padding: 32px 16px;\n    }\n\n    .lyora-reviews-title {\n      font-size: 22px;\n    }\n\n    .lyora-histogram {\n      padding: 16px;\n    }\n\n    .lyora-review-item {\n      padding: 16px;\n    }\n  }\n</style>\n\n<div class=\"lyora-reviews-section\">\n  <div class=\"lyora-reviews-container\">\n\n    <!-- Header -->\n    <div class=\"lyora-reviews-header\">\n      <h2 class=\"lyora-reviews-title\">Kundenbewertungen</h2>\n      \n      <div class=\"lyora-reviews-summary\">\n        <div class=\"lyora-reviews-stars\">\n          <svg viewbox=\"0 0 16 16\" fill=\"#FFD300\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"></path></svg>\n          <svg viewbox=\"0 0 16 16\" fill=\"#FFD300\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"></path></svg>\n          <svg viewbox=\"0 0 16 16\" fill=\"#FFD300\"><path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.