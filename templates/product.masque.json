        "collapsible_text_DbJmjV": {
          "type": "collapsible_text",
          "settings": {
            "icon": "none",
            "icon_width": 20,
            "title": "FORMULE CORÉENNE",
            "content": "<p><strong>Une synergie d'actifs de haute performance, développée dans nos laboratoires de Séoul.</strong></p><ul><li><strong>Bio-collagène hydrolysé</strong> : Stimule la production naturelle de collagène pour raffermir et revitaliser la peau en profondeur.</li><li><strong>Acide hyaluronique (hyaluronates de sodium)</strong> : Hydrate et repulpe instantanément pour un effet lissant visible dès la première application.</li><li><strong>Niacinamide concentré</strong> : Unifie le teint, réduit les pores dilatés et illumine la peau durablement.</li><li><strong>Filtrat de ferment Galactomyces</strong> : Antioxydant puissant qui améliore la clarté, l'éclat et la texture de la peau.</li><li><strong>Chondrus Crispus (algue rouge)</strong> : Source de minéraux essentiels, nourrit et hydrate intensément.</li><li><strong>Complexe d'acides aminés</strong> (Alanine, Sérine, Glycine) : Renforcent la barrière cutanée et revitalisent la peau en profondeur.</li><li><strong>Allantoïne</strong> : Apaise et régénère, parfait pour les peaux sensibles et réactives.</li><li><strong>Glycérine végétale</strong> : Maintient l'hydratation optimale tout au long de la journée.</li></ul><p><em><strong>Notre engagement :</strong></em><em> 98% d'ingrédients d'origine naturelle, sans parabènes, sulfates ni silicones. Chaque actif est sélectionné pour son efficacité cliniquement prouvée.</em></p>",
            "page": ""
          }
        },
