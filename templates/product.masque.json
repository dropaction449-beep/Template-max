    "custom_html_7cFR3p": {
      "type": "custom-html",
      "name": "Custom HTML",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "html": "<style>\n  .lyora-edu-section {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    padding: 48px 20px;\n    background: #fff5ef;\n    max-width: 100%;\n  }\n\n  .lyora-edu-container {\n    max-width: 800px;\n    margin: 0 auto;\n  }\n\n  .lyora-edu-title {\n    font-size: 28px;\n    font-weight: 800;\n    color: #1a1200;\n    line-height: 1.3;\n    margin-bottom: 16px;\n    text-align: center;\n  }\n\n  .lyora-edu-title u {\n    text-decoration: underline;\n    text-decoration-thickness: 2px;\n    text-underline-offset: 4px;\n  }\n\n  .lyora-edu-subtitle {\n    font-size: 16px;\n    font-style: italic;\n    color: #666;\n    margin-bottom: 24px;\n    text-align: center;\n  }\n\n  .lyora-edu-body {\n    font-size: 15px;\n    color: #333;\n    line-height: 1.7;\n    margin-bottom: 16px;\n  }\n\n  .lyora-edu-body strong {\n    font-weight: 600;\n    color: #1a1200;\n  }\n\n  /* Accordion */\n  .lyora-accordion {\n    margin: 32px 0;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n\n  .lyora-acc-item {\n    background: white;\n    border: 2px solid #1a1200;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n\n  .lyora-acc-trigger {\n    width: 100%;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 14px 18px;\n    background: white;\n    border: none;\n    cursor: pointer;\n    text-align: left;\n    gap: 16px;\n  }\n\n  .lyora-acc-trigger span {\n    font-size: 14px;\n    font-weight: 600;\n    color: #1a1200;\n    line-height: 1.4;\n  }\n\n  .lyora-acc-icon {\n    font-size: 22px;\n    font-weight: 300;\n    color: #1a1200;\n    flex-shrink: 0;\n    line-height: 1;\n  }\n\n  .lyora-acc-item.open .lyora-acc-icon {\n    transform: rotate(45deg);\n  }\n\n  .lyora-acc-content {\n    display: none;\n    padding: 0 18px 16px;\n    font-size: 13px;\n    color: #555;\n    line-height: 1.7;\n    border-top: 1px solid #e5e5e5;\n  }\n\n  .lyora-acc-item.open .lyora-acc-content {\n    display: block;\n  }\n\n  /* CTA Button */\n  .lyora-edu-cta {\n    display: block;\n    width: 100%;\n    max-width: 400px;\n    margin: 28px auto 0;\n    padding: 13px 20px;\n    background: #f7c948;\n    color: #111;\n    font-size: 13px;\n    font-weight: 900;\n    text-align: center;\n    letter-spacing: 1.5px;\n    border: 2px solid #111;\n    border-radius: 10px;\n    box-shadow: 0 2px 0 #111;\n    cursor: pointer;\n    text-transform: uppercase;\n    text-decoration: none;\n    box-sizing: border-box;\n  }\n\n  .lyora-edu-cta:active {\n    transform: translateY(1px);\n    box-shadow: 0 1px 0 #111;\n  }\n\n  /* Responsive */\n  @media (max-width: 768px) {\n    .lyora-edu-section {\n      padding: 32px 16px;\n    }\n\n    .lyora-edu-title {\n      font-size: 22px;\n    }\n\n    .lyora-edu-subtitle {\n      font-size: 14px;\n    }\n\n    .lyora-edu-body {\n      font-size: 14px;\n    }\n\n    .lyora-acc-trigger {\n      padding: 16px 18px;\n    }\n\n    .lyora-acc-trigger span {\n      font-size: 14px;\n    }\n\n    .lyora-acc-content {\n      font-size: 13px;\n    }\n  }\n</style>\n\n<div class=\"lyora-edu-section\">\n  <div class=\"lyora-edu-container\">\n\n    <h2 class=\"lyora-edu-title\">Warum Sie <u>Trotzdem Erschöpft</u> Bleiben — Obwohl Sie Gut Essen</h2>\n\n    <p class=\"lyora-edu-subtitle\">Der Teufelskreis, den niemand erklärt</p>\n\n    <p class=\"lyora-edu-body\">Sie achten auf Ihre Ernährung. Und trotzdem ändert sich nichts.</p>\n\n    <p class=\"lyora-edu-body\">Das Problem? Ein <strong>toxisches Trio</strong>, das alles sabotiert: überlastete Leber + unsichtbare Parasiten + entzündeter Darm. Das Schlimmste? Sie befeuern sich gegenseitig — ein endloser Kreislauf.</p>\n\n    <div class=\"lyora-accordion\">\n\n      <div class=\"lyora-acc-item\">\n        <button class=\"lyora-acc-trigger\" onclick=\"toggleLyoraAcc(this)\">\n          <span>Wie dieses Trio Ihren Körper sabotiert</span>\n          <span class=\"lyora-acc-icon\">+</span>\n        </button>\n        <div class=\"lyora-acc-content\">\n          Eine überlastete Leber kann Giftstoffe nicht mehr effizient filtern. Diese gelangen ins Blut, fördern Entzündungen im Darm und schaffen ein ideales Milieu für Parasiten — die wiederum die Leber weiter belasten. Ein Kreislauf, der sich selbst verstärkt.\n        </div>\n      </div>\n\n      <div class=\"lyora-acc-item\">\n        <button class=\"lyora-acc-trigger\" onclick=\"toggleLyoraAcc(this)\">\n          <span>Reicht ein einziges Nahrungsergänzungsmittel nicht?</span>\n          <span class=\"lyora-acc-icon\">+</span>\n        </button>\n        <div class=\"lyora-acc-content\">\n          Nein — weil das Problem dreidimensional ist. Ein Produkt, das nur die Leber anspricht, lässt Darm und Parasiten unberührt. <strong>LYORA</strong> wurde entwickelt, um alle drei Ursachen gleichzeitig zu behandeln.\n        </div>\n      </div>\n\n      <div class=\"lyora-acc-item\">\n        <button class=\"lyora-acc-trigger\" onclick=\"toggleLyoraAcc(this)\">\n          <span>Wie erkenne ich, ob das mein Problem ist?</span>\n          <span class=\"lyora-acc-icon\">+</span>\n        </button>\n        <div class=\"lyora-acc-content\">\n          Anhaltende Müdigkeit trotz gutem Schlaf, Blähbauch, Verdauungsprobleme, Hautprobleme oder Konzentrationsschwäche — diese Symptome deuten oft auf das toxische Trio hin, ohne dass klassische Bluttests etwas zeigen.\n        </div>\n      </div>\n\n    </div>\n\n    <a href=\"#\" class=\"lyora-edu-cta\">Jetzt meine 3-in-1 Detox starten</a>\n\n  </div>\n</div>\n\n<script>\n  function toggleLyoraAcc(btn) {\n    var item = btn.closest('.lyora-acc-item');\n    item.classList.toggle('open');\n  }\n</script>",
        "background": "#fff5ef",
        "background_gradient": "",
        "text_color": "#fff5ef"
      }
    },
