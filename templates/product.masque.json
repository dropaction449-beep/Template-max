    "custom_html_LdDiF8": {
      "type": "custom-html",
      "name": "Custom HTML",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "html": "<style>\n  .ingredients-section {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    padding: 16px 12px;\n    background: #fff;\n    max-width: 100%;\n  }\n\n  .ingredients-title {\n    font-size: 18px;\n    font-weight: 800;\n    color: #1a1200;\n    line-height: 1.25;\n    margin-bottom: 14px;\n    text-align: center;\n  }\n\n  /* Accordion Ingredients */\n  .accordion-ingredients {\n    margin: 12px 0;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n\n  .ing-item {\n    border: 1px solid #e0e0e0;\n    border-radius: 10px;\n    overflow: hidden;\n    background: #fff;\n    transition: box-shadow 0.3s ease;\n  }\n\n  .ing-item:hover {\n    box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n  }\n\n  .ing-trigger {\n    width: 100%;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 12px 16px;\n    background: #fff;\n    border: none;\n    cursor: pointer;\n    text-align: left;\n    gap: 12px;\n  }\n\n  .ing-left {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    flex: 1;\n  }\n\n  .ing-icon-img {\n    width: 42px;\n    height: 42px;\n    border-radius: 50%;\n    object-fit: cover;\n    flex-shrink: 0;\n  }\n\n  .ing-trigger span {\n    font-size: 13px;\n    font-weight: 500;\n    color: #2c2c2c;\n    line-height: 1.3;\n  }\n\n  .ing-plus {\n    font-size: 20px;\n    color: #666;\n    flex-shrink: 0;\n    line-height: 1;\n    transition: transform 0.3s ease;\n  }\n\n  .ing-item.open .ing-plus {\n    transform: rotate(45deg);\n  }\n\n  .ing-content {\n    display: none;\n    padding: 0 16px 14px;\n    font-size: 12px;\n    color: #555;\n    line-height: 1.6;\n  }\n\n  .ing-item.open .ing-content {\n    display: block;\n  }\n\n  .ing-content-inner {\n    padding-top: 8px;\n    border-top: 1px solid #f0f0f0;\n  }\n\n  .ing-content h4 {\n    color: #2c2c2c;\n    font-size: 13px;\n    font-weight: 600;\n    margin-bottom: 6px;\n  }\n\n  .ing-content ul {\n    margin-left: 18px;\n    margin-top: 6px;\n  }\n\n  .ing-content li {\n    margin-bottom: 4px;\n  }\n\n  .ing-content strong {\n    font-weight: 600;\n    color: #2c2c2c;\n  }\n\n  /* Style spécial pour le dernier item (liste complète) */\n  .ing-item.full-list .ing-left {\n    justify-content: center;\n  }\n\n  .ing-item.full-list .ing-trigger span {\n    font-weight: 600;\n  }\n</style>\n\n<div class=\"ingredients-section\">\n\n  <h2 class=\"ingredients-title\">Natürliche Inhaltsstoffe &amp; Vorteile</h2>\n\n  <div class=\"accordion-ingredients\">\n\n    <!-- Chardon-Marie / Mariendistel -->\n    <div class=\"ing-item\">\n      <button class=\"ing-trigger\" onclick=\"toggleIngredient(this)\">\n        <div class=\"ing-left\">\n          <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/a1f57791-4aaf-44a3-9c75-cdfb0bc7b32a\" alt=\"Mariendistel\" class=\"ing-icon-img\">\n          <span>Mariendistel (Extrakt 10:1) — 333mg</span>\n        </div>\n        <span class=\"ing-plus\">+</span>\n      </button>\n      <div class=\"ing-content\">\n        <div class=\"ing-content-inner\">\n          <h4>Vorteile der Mariendistel:</h4>\n          <ul>\n            <li>\n<strong>Leberschutz:</strong> Unterstützt die Regeneration von Leberzellen</li>\n            <li>\n<strong>Entgiftung:</strong> Hilft, Giftstoffe aus dem Körper zu entfernen</li>\n            <li>\n<strong>Starkes Antioxidans:</strong> Bekämpft freie Radikale</li>\n            <li>\n<strong>Verdauung:</strong> Fördert eine bessere Verdauungsfunktion</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <!-- Gingembre / Ingwer -->\n    <div class=\"ing-item\">\n      <button class=\"ing-trigger\" onclick=\"toggleIngredient(this)\">\n        <div class=\"ing-left\">\n          <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/9a4fb164-6d01-4568-b57c-af295a0c848f\" alt=\"Ingwer\" class=\"ing-icon-img\">\n          <span>Ingwer (Extrakt 10:1) — 100mg</span>\n        </div>\n        <span class=\"ing-plus\">+</span>\n      </button>\n      <div class=\"ing-content\">\n        <div class=\"ing-content-inner\">\n          <h4>Vorteile von Ingwer:</h4>\n          <ul>\n            <li>\n<strong>Verdauung:</strong> Reduziert Übelkeit und verbessert die Verdauung</li>\n            <li>\n<strong>Entzündungshemmend:</strong> Lindert Muskelschmerzen</li>\n            <li>\n<strong>Immunität:</strong> Stärkt das Immunsystem</li>\n            <li>\n<strong>Durchblutung:</strong> Verbessert die Blutzirkulation</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <!-- Pissenlit / Löwenzahn -->\n    <div class=\"ing-item\">\n      <button class=\"ing-trigger\" onclick=\"toggleIngredient(this)\">\n        <div class=\"ing-left\">\n          <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/d3f0b81c-1b6f-45e2-a2d1-9075122ebc94\" alt=\"Löwenzahn\" class=\"ing-icon-img\">\n          <span>Löwenzahn (Extrakt 10:1) — 167mg</span>\n        </div>\n        <span class=\"ing-plus\">+</span>\n      </button>\n      <div class=\"ing-content\">\n        <div class=\"ing-content-inner\">\n          <h4>Vorteile von Löwenzahn:</h4>\n          <ul>\n            <li>\n<strong>Natürliches Diuretikum:</strong> Fördert die Wasserausscheidung</li>\n            <li>\n<strong>Leber-Detox:</strong> Unterstützt die Leberfunktion</li>\n            <li>\n<strong>Reich an Nährstoffen:</strong> Quelle der Vitamine A, C und K</li>\n            <li>\n<strong>Verdauung:</strong> Regt Appetit und Verdauung an</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <!-- Curcuma / Kurkuma -->\n    <div class=\"ing-item\">\n      <button class=\"ing-trigger\" onclick=\"toggleIngredient(this)\">\n        <div class=\"ing-left\">\n          <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/6fcc29ba-9aab-44d6-9708-bbecfa481e69\" alt=\"Kurkuma\" class=\"ing-icon-img\">\n          <span>Kurkuma (Extrakt 10:1) — 100mg</span>\n        </div>\n        <span class=\"ing-plus\">+</span>\n      </button>\n      <div class=\"ing-content\">\n        <div class=\"ing-content-inner\">\n          <h4>Vorteile von Kurkuma:</h4>\n          <ul>\n            <li>\n<strong>Entzündungshemmend:</strong> Reduziert Entzündungen im Körper</li>\n            <li>\n<strong>Antioxidans:</strong> Schützt Zellen vor oxidativem Stress</li>\n            <li>\n<strong>Gehirnfunktion:</strong> Unterstützt kognitive Gesundheit</li>\n            <li>\n<strong>Gelenkgesundheit:</strong> Lindert Gelenkbeschwerden</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <!-- Chicorée / Zichorie -->\n    <div class=\"ing-item\">\n      <button class=\"ing-trigger\" onclick=\"toggleIngredient(this)\">\n        <div class=\"ing-left\">\n          <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/d7ee3e09-b21e-4bd0-8a0f-f861b19f2950\" alt=\"Zichorie\" class=\"ing-icon-img\">\n          <span>Zichorie (Inulin) — 83mg</span>\n        </div>\n        <span class=\"ing-plus\">+</span>\n      </button>\n      <div class=\"ing-content\">\n        <div class=\"ing-content-inner\">\n          <h4>Vorteile von Zichorie:</h4>\n          <ul>\n            <li>\n<strong>Präbiotikum:</strong> Fördert gesunde Darmbakterien</li>\n            <li>\n<strong>Verdauungsgesundheit:</strong> Unterstützt die Darmfunktion</li>\n            <li>\n<strong>Blutzuckerkontrolle:</strong> Hilft, den Blutzuckerspiegel zu regulieren</li>\n            <li>\n<strong>Ballaststoffreich:</strong> Fördert die Sättigung und Verdauung</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <!-- Patience Crépue / Krauser Ampfer -->\n    <div class=\"ing-item\">\n      <button class=\"ing-trigger\" onclick=\"toggleIngredient(this)\">\n        <div class=\"ing-left\">\n          <img src=\"https://assets.replocdn.com/projects/194b47ce-750c-4720-9b95-214a0b3df524/f88712bf-e999-4c47-b213-4d977687187f\" alt=\"Krauser Ampfer\" class=\"ing-icon-img\">\n          <span>Krauser Ampfer (Extrakt 10:1) — 167mg</span>\n        </div>\n        <span class=\"ing-plus\">+</span>\n      </button>\n      <div class=\"ing-content\">\n        <div class=\"ing-content-inner\">\n          <h4>Vorteile von Krausem Ampfer:</h4>\n          <ul>\n            <li>\n<strong>Verdauungsfördernd:</strong> Unterstützt die Darmgesundheit</li>\n            <li>\n<strong>Entgiftung:</strong> Hilft bei der Reinigung des Verdauungstrakts</li>\n            <li>\n<strong>Reich an Eisen:</strong> Unterstützt die Blutbildung</li>\n            <li>\n<strong>Traditionelle Anwendung:</strong> Seit Jahrhunderten in der Kräutermedizin verwendet</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <!-- Liste Complète / Vollständige Liste -->\n    <div class=\"ing-item full-list\">\n      <button class=\"ing-trigger\" onclick=\"toggleIngredient(this)\">\n        <div class=\"ing-left\">\n          <span>Vollständige Zutatenliste</span>\n        </div>\n        <span class=\"ing-plus\">+</span>\n      </button>\n      <div class=\"ing-content\">\n        <div class=\"ing-content-inner\">\n          <h4>Alle Inhaltsstoffe pro Kapsel:</h4>\n          <ul>\n            <li>Mariendistel (Extrakt 10:1) — 333mg</li>\n            <li>Löwenzahn (Extrakt 10:1) — 167mg</li>\n            <li>Krauser Ampfer (Extrakt 10:1) — 167mg</li>\n            <li>Ingwer (Extrakt 10:1) — 100mg</li>\n            <li>Kurkuma (Extrakt 10:1) — 100mg</li>\n            <li>Zichorie (Inulin) — 83mg</li>\n            <li>Schwarzer Pfeffer (Extrakt 95% Piperin) — 5mg</li>\n          </ul>\n          <p style=\"margin-top: 12px; font-size: 13px; color: #666;\">\n            <strong>Weitere Inhaltsstoffe:</strong> Pflanzliche Kapsel (Hydroxypropylmethylcellulose), Rieselhilfe (Magnesiumstearat pflanzlich)\n          </p>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n</div>\n\n<script>\n  function toggleIngredient(btn) {\n    var item = btn.closest('.ing-item');\n    \n    // Fermer tous les autres accordéons\n    document.querySelectorAll('.ing-item').forEach(function(otherItem) {\n      if (otherItem !== item) {\n        otherItem.classList.remove('open');\n      }\n    });\n    \n    // Toggle l'accordéon cliqué\n    item.classList.toggle('open');\n  }\n</script>",
        "background": "#fff5ef",
        "background_gradient": "",
        "text_color": "#fff5ef"
      }
