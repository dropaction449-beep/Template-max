        "remove_horizontal_spacing": true,
        "html": "<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Gesundheitsmagazin — Lyora</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,600&amp;family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300;1,400&amp;family=DM+Sans:wght@300;400;500;600&amp;display=swap\" rel=\"stylesheet\">\n<style>\n:root {\n  --green: #1a5c1a;\n  --green-light: #2d8a2d;\n  --green-accent: #5ab040;\n  --green-pale: #e8f5e0;\n  --red-alert: #c0392b;\n  --gold: #b8860b;\n  --text: #1a1a1a;\n  --text-muted: #555;\n  --border: #d4e8c4;\n  --white: #ffffff;\n  --cream: #fafaf7;\n  --serif: 'Playfair Display', Georgia, serif;\n  --body-serif: 'Source Serif 4', Georgia, serif;\n  --sans: 'DM Sans', system-ui, sans-serif;\n}\n\n* { margin: 0; padding: 0; box-sizing: border-box; }\n\nbody {\n  background: var(--cream);\n  color: var(--text);\n  font-family: var(--body-serif);\n  font-size: 17px;\n  line-height: 1.75;\n}\n\n/* ── TOP BANNER ── */\n.top-banner {\n  background: var(--green);\n  color: white;\n  text-align: center;\n  padding: 10px 20px;\n  font-family: var(--sans);\n  font-size: 13px;\n  font-weight: 500;\n  letter-spacing: 0.5px;\n}\n.top-banner span { margin: 0 16px; opacity: 0.9; }\n.top-banner strong { opacity: 1; }\n\n/* ── MASTHEAD ── */\n.masthead {\n  background: white;\n  border-bottom: 2px solid var(--green);\n  padding: 14px 20px;\n  text-align: center;\n}\n.masthead-label {\n  font-family: var(--sans);\n  font-size: 11px;\n  letter-spacing: 4px;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  margin-bottom: 4px;\n}\n.masthead-title {\n  font-family: var(--serif);\n  font-size: clamp(22px, 4vw, 36px);\n  font-weight: 700;\n  color: var(--green);\n  letter-spacing: -0.5px;\n}\n.masthead-subtitle {\n  font-family: var(--sans);\n  font-size: 12px;\n  color: var(--text-muted);\n  margin-top: 4px;\n}\n\n/* ── ALERT BAR ── */\n.alert-bar {\n  background: #fff8e1;\n  border-left: 4px solid #f59e0b;\n  padding: 12px 20px;\n  font-family: var(--sans);\n  font-size: 13px;\n  color: #78350f;\n  text-align: center;\n}\n\n/* ── MAIN WRAPPER ── */\n.page-wrapper {\n  max-width: 780px;\n  margin: 0 auto;\n  padding: 0 20px;\n}\n\n/* ── ARTICLE HEADER ── */\n.article-header {\n  background: white;\n  padding: 40px 40px 32px;\n  margin: 24px 0 0;\n  border: 1px solid var(--border);\n  border-radius: 4px;\n}\n\n@media (max-width: 600px) {\n  .article-header { padding: 24px 20px 20px; }\n}\n\n.article-kicker {\n  font-family: var(--sans);\n  font-size: 11px;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: var(--green);\n  font-weight: 600;\n  margin-bottom: 12px;\n}\n\n.article-headline {\n  font-family: var(--serif);\n  font-size: clamp(24px, 4vw, 38px);\n  font-weight: 900;\n  line-height: 1.15;\n  color: var(--text);\n  margin-bottom: 16px;\n}\n\n.article-deck {\n  font-family: var(--body-serif);\n  font-size: clamp(16px, 2.5vw, 19px);\n  font-style: italic;\n  color: var(--text-muted);\n  line-height: 1.6;\n  margin-bottom: 20px;\n  padding-bottom: 20px;\n  border-bottom: 1px solid var(--border);\n}\n\n.article-meta {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-wrap: wrap;\n}\n.author-avatar {\n  width: 44px;\n  height: 44px;\n  border-radius: 50%;\n  background: var(--green-pale);\n  border: 2px solid var(--border);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: var(--serif);\n  font-size: 18px;\n  color: var(--green);\n  flex-shrink: 0;\n}\n.author-info { flex: 1; }\n.author-name {\n  font-family: var(--sans);\n  font-size: 14px;\n  font-weight: 600;\n  color: var(--text);\n}\n.author-date {\n  font-family: var(--sans);\n  font-size: 12px;\n  color: var(--text-muted);\n}\n.rating-badge {\n  background: var(--green-pale);\n  border: 1px solid var(--border);\n  border-radius: 20px;\n  padding: 4px 12px;\n  font-family: var(--sans);\n  font-size: 12px;\n  color: var(--green);\n  font-weight: 600;\n  white-space: nowrap;\n}\n\n/* ── MEDIA LOGOS ── */\n.media-logos {\n  background: white;\n  border: 1px solid var(--border);\n  border-radius: 4px;\n  padding: 16px 24px;\n  margin: 16px 0;\n  text-align: center;\n}\n.media-logos-label {\n  font-family: var(--sans);\n  font-size: 10px;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  margin-bottom: 12px;\n}\n.media-logos-row {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 24px;\n  flex-wrap: wrap;\n}\n.media-logo {\n  font-family: var(--serif);\n  font-size: 13px;\n  font-weight: 700;\n  color: #888;\n  letter-spacing: 0.5px;\n  text-transform: uppercase;\n  padding: 4px 8px;\n  border: 1px solid #ddd;\n  border-radius: 3px;\n}\n\n/* ── ARTICLE BODY ── */\n.article-body {\n  background: white;\n  border: 1px solid var(--border);\n  border-radius: 4px;\n  padding: 40px;\n  margin: 16px 0;\n}\n@media (max-width: 600px) {\n  .article-body { padding: 24px 20px; }\n}\n\n.article-body p {\n  margin-bottom: 20px;\n  color: var(--text);\n}\n\n.article-body p strong { color: var(--text); }\n\n/* ── SECTION HEADERS ── */\n.section-header {\n  font-family: var(--serif);\n  font-size: clamp(20px, 3vw, 26px);\n  font-weight: 700;\n  color: var(--text);\n  margin: 36px 0 16px;\n  padding-top: 20px;\n  border-top: 2px solid var(--green-pale);\n  line-height: 1.25;\n}\n\n.section-header.red {\n  color: var(--red-alert);\n  border-top-color: #fde8e8;\n}\n\n/* ── PULL QUOTE ── */\n.pull-quote {\n  border-left: 4px solid var(--green);\n  margin: 28px 0;\n  padding: 16px 24px;\n  background: var(--green-pale);\n  border-radius: 0 4px 4px 0;\n}\n.pull-quote p {\n  font-family: var(--serif);\n  font-size: clamp(16px, 2.5vw, 20px);\n  font-style: italic;\n  color: var(--green);\n  line-height: 1.5;\n  margin: 0 !important;\n}\n\n/* ── STAT BOX ── */\n.stat-box {\n  background: #fff8e1;\n  border: 2px solid #f59e0b;\n  border-radius: 6px;\n  padding: 24px;\n  margin: 28px 0;\n  text-align: center;\n}\n.stat-number {\n  font-family: var(--serif);\n  font-size: clamp(36px, 6vw, 54px);\n  font-weight: 900;\n  color: var(--red-alert);\n  line-height: 1;\n  margin-bottom: 8px;\n}\n.stat-label {\n  font-family: var(--sans);\n  font-size: 14px;\n  color: var(--text-muted);\n  max-width: 360px;\n  margin: 0 auto;\n}\n.stat-source {\n  font-family: var(--sans);\n  font-size: 11px;\n  color: #aaa;\n  margin-top: 8px;\n  font-style: italic;\n}\n\n/* ── IMAGE PLACEHOLDER ── */\n.img-block {\n  margin: 28px 0;\n  text-align: center;\n}\n.img-placeholder {\n  background: linear-gradient(135deg, var(--green-pale), #d0e8c0);\n  border: 1px solid var(--border);\n  border-radius: 6px;\n  padding: 60px 20px;\n  color: var(--green);\n  font-family: var(--sans);\n  font-size: 13px;\n  font-style: italic;\n}\n.img-caption {\n  font-family: var(--sans);\n  font-size: 12px;\n  color: var(--text-muted);\n  margin-top: 8px;\n  font-style: italic;\n}\n\n/* ── SYMPTOM LIST ── */\n.symptom-list {\n  background: #fff5f5;\n  border: 1px solid #fca5a5;\n  border-radius: 6px;\n  padding: 24px;\n  margin: 24px 0;\n}\n.symptom-list-title {\n  font-family: var(--sans);\n  font-size: 13px;\n  font-weight: 700;\n  letter-spacing: 1px;\n  text-transform: uppercase;\n  color: var(--red-alert);\n  margin-bottom: 14px;\n}\n.symptom-item {\n  display: flex;\n  gap: 10px;\n  margin-bottom: 10px;\n  font-size: 15px;\n  line-height: 1.5;\n}\n.symptom-icon { color: var(--red-alert); flex-shrink: 0; margin-top: 2px; }\n.symptom-text em { font-style: normal; color: var(--text-muted); font-size: 13px; }\n\n/* ── PROBLEM BOXES ── */\n.problem-box {\n  border: 1px solid #fca5a5;\n  border-left: 4px solid var(--red-alert);\n  border-radius: 4px;\n  padding: 20px 24px;\n  margin: 20px 0;\n  background: white;\n}\n.problem-box-title {\n  font-family: var(--sans);\n  font-size: 12px;\n  font-weight: 700;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  color: var(--red-alert);\n  margin-bottom: 8px;\n}\n.problem-box p { margin: 0 !important; font-size: 15px; }\n\n/* ── DOCTOR QUOTE ── */\n.doctor-quote {\n  background: var(--green-pale);\n  border: 1px solid var(--border);\n  border-radius: 6px;\n  padding: 28px;\n  margin: 28px 0;\n  position: relative;\n}\n.doctor-quote::before {\n  content: '\"';\n  font-family: var(--serif);\n  font-size: 80px;\n  color: var(--green-light);\n  opacity: 0.2;\n  position: absolute;\n  top: 8px;\n  left: 16px;\n  line-height: 1;\n}\n.doctor-quote p {\n  font-family: var(--body-serif);\n  font-size: 16px;\n  font-style: italic;\n  color: var(--text);\n  position: relative;\n  z-index: 1;\n  margin: 0 !important;\n}\n.doctor-name {\n  font-family: var(--sans);\n  font-size: 13px;\n  font-weight: 600;\n  color: var(--green);\n  margin-top: 12px;\n  font-style: normal;\n}\n\n/* ── INGREDIENT CARD ── */\n.ingredient-card {\n  border: 1px solid var(--border);\n  border-left: 4px solid var(--green);\n  border-radius: 4px;\n  padding: 20px 24px;\n  margin: 16px 0;\n  background: white;\n}\n.ingredient-name {\n  font-family: var(--sans);\n  font-size: 13px;\n  font-weight: 700;\n  color: var(--green);\n  letter-spacing: 1px;\n  text-transform: uppercase;\n  margin-bottom: 6px;\n}\n.ingredient-dose {\n  display: inline-block;\n  background: var(--green-pale);\n  color: var(--green);\n  font-family: var(--sans);\n  font-size: 11px;\n  font-weight: 600;\n  padding: 2px 8px;\n  border-radius: 10px;\n  margin-bottom: 10px;\n}\n.ingredient-card p { font-size: 15px; margin: 0 !important; }\n\n/* ── TIMELINE ── */\n.timeline { margin: 24px 0; }\n.timeline-item {\n  display: flex;\n  gap: 20px;\n  margin-bottom: 24px;\n  align-items: flex-start;\n}\n.timeline-marker {\n  flex-shrink: 0;\n  width: 52px;\n  height: 52px;\n  border-radius: 50%;\n  background: var(--green);\n  color: white;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: var(--sans);\n  font-size: 11px;\n  font-weight: 700;\n  text-align: center;\n  line-height: 1.2;\n}\n.timeline-content { flex: 1; padding-top: 4px; }\n.timeline-title {\n  font-family: var(--sans);\n  font-size: 15px;\n  font-weight: 700;\n  color: var(--green);\n  margin-bottom: 6px;\n}\n.timeline-text { font-size: 15px; color: var(--text); }\n\n/* ── CTA SECTION ── */\n.cta-section {\n  background: linear-gradient(135deg, var(--green) 0%, #0f3d0f 100%);\n  border-radius: 8px;\n  padding: 40px;\n  margin: 32px 0;\n  text-align: center;\n  color: white;\n}\n@media (max-width: 600px) { .cta-section { padding: 28px 20px; } }\n\n.cta-urgency {\n  display: inline-block;\n  background: #f59e0b;\n  color: #1a1a1a;\n  font-family: var(--sans);\n  font-size: 11px;\n  font-weight: 700;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  padding: 5px 14px;\n  border-radius: 20px;\n  margin-bottom: 16px;\n}\n.cta-headline {\n  font-family: var(--serif);\n  font-size: clamp(22px, 4vw, 32px);\n  font-weight: 900;\n  color: white;\n  margin-bottom: 12px;\n  line-height: 1.2;\n}\n.cta-subheadline {\n  font-family: var(--sans);\n  font-size: 16px;\n  color: rgba(255,255,255,0.85);\n  margin-bottom: 24px;\n}\n.cta-offer {\n  background: rgba(255,255,255,0.12);\n  border: 1px solid rgba(255,255,255,0.25);\n  border-radius: 6px;\n  padding: 16px 24px;\n  display: inline-block;\n  margin-bottom: 24px;\n  font-family: var(--sans);\n  font-size: 18px;\n  font-weight: 700;\n  color: #fef08a;\n  letter-spacing: 0.5px;\n}\n.cta-button {\n  display: block;\n  background: #5ab040;\n  color: white;\n  text-decoration: none;\n  font-family: var(--sans);\n  font-size: 17px;\n  font-weight: 700;\n  padding: 18px 32px;\n  border-radius: 6px;\n  margin: 0 auto 16px;\n  max-width: 420px;\n  letter-spacing: 0.5px;\n  transition: background 0.2s;\n  cursor: pointer;\n  border: none;\n}\n.cta-button:hover { background: #4a9835; }\n.cta-guarantee {\n  font-family: var(--sans);\n  font-size: 13px;\n  color: rgba(255,255,255,0.7);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 6px;\n}\n\n/* ── TESTIMONIALS ── */\n.testimonial-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 16px;\n  margin: 24px 0;\n}\n@media (max-width: 540px) { .testimonial-grid { grid-template-columns: 1fr; } }\n\n.testimonial-card {\n  background: white;\n  border: 1px solid var(--border);\n  border-radius: 6px;\n  padding: 20px;\n}\n.testimonial-stars { color: #f59e0b; font-size: 14px; margin-bottom: 8px; }\n.testimonial-text {\n  font-family: var(--body-serif);\n  font-size: 14px;\n  font-style: italic;\n  color: var(--text);\n  margin-bottom: 10px;\n  line-height: 1.55;\n}\n.testimonial-author {\n  font-family: var(--sans);\n  font-size: 12px;\n  font-weight: 600;\n  color: var(--text-muted);\n}\n.testimonial-verified {\n  font-size: 11px;\n  color: var(--green);\n  font-weight: normal;\n}\n\n/* ── FAQ ── */\n.faq-item {\n  border-bottom: 1px solid var(--border);\n  padding: 18px 0;\n}\n.faq-question {\n  font-family: var(--sans);\n  font-size: 15px;\n  font-weight: 600;\n  color: var(--text);\n  margin-bottom: 8px;\n  cursor: pointer;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.faq-answer {\n  font-size: 15px;\n  color: var(--text-muted);\n  line-height: 1.65;\n}\n\n/* ── STICKY CTA MOBILE ── */\n.sticky-cta {\n  position: fixed;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  background: var(--green);\n  padding: 12px 20px;\n  z-index: 100;\n  display: none;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  box-shadow: 0 -4px 20px rgba(0,0,0,0.2);\n}\n@media (max-width: 768px) { .sticky-cta { display: flex; } }\n.sticky-cta-text {\n  font-family: var(--sans);\n  font-size: 13px;\n  color: white;\n  line-height: 1.3;\n}\n.sticky-cta-text strong { display: block; font-size: 14px; }\n.sticky-cta-btn {\n  background: #5ab040;\n  color: white;\n  font-family: var(--sans);\n  font-size: 13px;\n  font-weight: 700;\n  padding: 10px 18px;\n  border-radius: 4px;\n  text-decoration: none;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n/* ── FOOTER ── */\n.page-footer {\n  background: #f0f0f0;\n  padding: 24px;\n  text-align: center;\n  font-family: var(--sans);\n  font-size: 11px;\n  color: #999;\n  margin-top: 40px;\n  margin-bottom: 60px;\n}\n</style>\n\n\n\n<!-- TOP BANNER -->\n<div class=\"top-banner\">\n  <span>🚚 <strong>Kostenloser Versand</strong></span>\n  <span>🎁 <strong>1 Flasche kaufen = 1 GRATIS</strong></span>\n  <span>✅ <strong>60 Tage Garantie</strong></span>\n</div>\n\n<!-- MASTHEAD -->\n<div class=\"masthead\">\n  <div class=\"masthead-label\">Gesundheitsmagazin Deutschland</div>\n  <div class=\"masthead-title\">Gesundheit &amp; Wohlbefinden™</div>\n  <div class=\"masthead-subtitle\">Unabhängige Berichterstattung seit 2018</div>\n</div>\n\n<!-- ALERT BAR -->\n<div class=\"alert-bar\">\n  ❗️ <strong>AKTUELLE MELDUNG:</strong> Lyora verzeichnet nach unserem Bericht im Spiegel Gesundheit eine beispiellose Nachfrage. Begrenzte Lagerbestände verfügbar.\n</div>\n\n<div class=\"page-wrapper\">\n\n  <!-- ARTICLE HEADER -->\n  <div class=\"article-header\">\n    <div class=\"article-kicker\">Exklusivbericht · Darmgesundheit</div>\n    <h1 class=\"article-headline\">„Ich dachte, ich werde verrückt. 4 Ärzte sagten mir, es sei Stress. Alle lagen falsch.\"</h1>\n    <p class=\"article-deck\">Die Geschichte einer Frau, die 3 Jahre lang erschöpft war — bis sie die „Stillen Mieter\" entdeckte, die 8 von 10 Ärzten nie suchen. Und das natürliche Protokoll, das in 21 Tagen alles verändert hat.</p>\n    <div class=\"article-meta\">\n      <div class=\"author-avatar\">KM</div>\n      <div class=\"author-info\">\n        <div class=\"author-name\">Von <strong>Katja Müller</strong>, Gesundheitsjournalistin</div>\n        <div class=\"author-date\">Veröffentlicht am 28. Februar 2026</div>\n      </div>\n      <div class=\"rating-badge\">★★★★★ 3.847 Bewertungen</div>\n    </div>\n  </div>\n\n  <!-- MEDIA LOGOS -->\n  <div class=\"media-logos\">\n    <div class=\"media-logos-label\">Gesehen in</div>\n    <div class=\"media-logos-row\">\n      <span class=\"media-logo\">ARD Gesundheit</span>\n      <span class=\"media-logo\">Spiegel Gesundheit</span>\n      <span class=\"media-logo\">Focus Online</span>\n      <span class=\"media-logo\">Apotheken Umschau</span>\n    </div>\n  </div>\n\n  <!-- ARTICLE BODY -->\n  <div class=\"article-body\">\n\n    <p>Was ich Ihnen heute erzählen werde, wagen die wenigsten Frauen laut auszusprechen.</p>\n    <p>Nicht gegenüber ihrem Arzt. Nicht gegenüber ihren Freundinnen. Manchmal nicht einmal gegenüber ihrem Partner.</p>\n    <p>Und trotzdem hat eine <strong>im Dezember 2024 im PLOS Neglected Tropical Diseases veröffentlichte Studie</strong> eine Zahl enthüllt, die Schlagzeilen machen sollte:</p>\n\n    <div class=\"stat-box\">\n      <div class=\"stat-number\">1 von 3</div>\n      <div class=\"stat-label\">Deutschen trägt Darmparasiten in sich — ohne es zu wissen. Analysiert mittels PCR — der zuverlässigsten verfügbaren Methode.</div>\n      <div class=\"stat-source\">Quelle: PLOS Neglected Tropical Diseases, Dez. 2024 · 33,2% der Bevölkerung betroffen</div>\n    </div>\n\n    <p>Und in <strong>78% der Fälle?</strong> Die Standardtests erkennen sie nicht.</p>\n    <p>Ich habe diese Realität vor 4 Monaten entdeckt. Und was ich erfahren habe, hat mein Verständnis von chronischer Erschöpfung, Bauchproblemen, unerklärlichen Heißhungerattacken — und sogar Hautproblemen — vollständig verändert.</p>\n    <p>Alles begann mit einer E-Mail von einer Leserin namens Lena K.</p>\n\n    <div class=\"pull-quote\">\n      <p>„Frau Müller, ich bin 42 Jahre alt. Seit 3 Jahren bin ich erschöpft. Ich habe 4 Ärzte konsultiert. Schilddrüse normal. Eisen normal. Hormone normal. Man sagt mir, es sei Stress, es sei in meinem Kopf. Aber ich WEISS, dass etwas nicht stimmt. Und vor 2 Monaten habe ich herausgefunden, was es war.\"</p>\n    </div>\n\n    <p>Ich hätte fast nicht geantwortet. Nach 12 Jahren Gesundheitsjournalismus habe ich ein Gespür für übertriebene Erfahrungsberichte entwickelt. Und „ich habe herausgefunden, was es war\" klang nach einer weiteren Geschichte über ein Wundermittel.</p>\n    <p>Ich antwortete dennoch. Wir schrieben uns. Drei Wochen später traf ich sie in einem Café in München.</p>\n    <p>Was Lena mir an diesem Tag erzählte, hat meine Sicht auf das verändert, was im Körper von Frauen zwischen 35 und 55 Jahren vorgeht. Und vor allem, warum die konventionelle Medizin völlig danebengreift.</p>\n\n    <h2 class=\"section-header\">DIE FRAU, DIE MIT 42 IHR LEBEN ZURÜCKGEWANN</h2>\n\n    <div class=\"img-block\">\n      <div class=\"img-placeholder\">\n        📸 Foto einfügen: Lena vorher / nachher (Vorher: November 2025 — aufgedunsen, grauer Teint, erschöpfter Blick / Nachher: hellwach, strahlend, energiegeladen)\n      </div>\n      <div class=\"img-caption\">Links: Lena K., November 2025. Rechts: dieselbe Frau — 3 Monate später.</div>\n    </div>\n\n    <p>Lena kommt ins Café. Ich erwarte eine erschöpfte Frau mit eingefallenen Zügen.</p>\n    <p>Was ich sehe: Eine lächelnde Frau mit leuchtendem Teint, spürbarer Energie.</p>\n    <p><em>„Ich weiß, was Sie denken\"</em>, sagt sie, während sie sich setzt. <em>„Sie fragen sich, wo die erschöpfte Frau ist, von der ich Ihnen geschrieben habe.\"</em></p>\n    <p>Sie holt ihr Handy heraus und zeigt mir ein Foto vom November 2025.</p>\n    <p>Ich bin sprachlos. Die Frau auf dem Foto sieht <strong>mindestens 10 Jahre älter</strong> aus als die, die mir gegenübersitzt. Aufgedunsenes Gesicht. Blau-violette Augenringe. Fahl-grauer Teint. Erloschener Blick.</p>\n    <p><em>„Das war vor 3 Monaten\"</em>, sagt Lena. <em>„Bevor ich verstanden habe, was seit Jahren in meinen Därmen lebte.\"</em></p>\n\n    <h2 class=\"section-header red\">3 JAHRE ÄRZTEMARATHON</h2>\n\n    <p>Lena erzählt mir ihren Leidensweg. Und je mehr sie spricht, desto mehr wird mir bewusst, wie sehr ihre Geschichte die Geschichte Tausender Frauen ist.</p>\n    <p>2022 hatte sie alles, um glücklich zu sein. Projektleiterin bei einer Münchner Marketingagentur. Verheiratet, zwei Kinder im Alter von 9 und 13 Jahren. Aktives Sozialleben.</p>\n    <p>Dann, schrittweise, veränderte sich etwas.</p>\n\n    <div class=\"symptom-list\">\n      <div class=\"symptom-list-title\">⚠️ Lenas Symptome — die Liste, die kein Arzt erklären konnte</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Chronische Erschöpfung</strong> <em>— „Ich machte Micro-Schläfchen auf der Toilette im Büro, um durchzuhalten\"</em></span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Dauerhaft aufgeblähter Bauch</strong> <em>— „Ich sah nach jeder Mahlzeit aus, als wäre ich im 5. Monat schwanger\"</em></span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Unkontrollierbarer Zuckerheißhunger</strong> <em>— „Um 16 Uhr war es stärker als ich — ich brauchte Schokolade\"</em></span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Fahle Haut, Akne mit 42</strong> <em>— „Das hatte ich nicht einmal als Teenager\"</em></span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Nächtliche Wachphasen zwischen 2 und 4 Uhr</strong> <em>— „Jede Nacht, wie ein Uhrwerk\"</em></span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Gehirnnebel</strong> <em>— „Ich verlor mitten im Gespräch den Faden\"</em></span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Unerklärliche Gewichtszunahme</strong> <em>— „+6 Kilo in 2 Jahren ohne Änderung meiner Gewohnheiten\"</em></span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Nächtliches Zähneknirschen</strong> <em>— „Ich habe einen Backenzahn gerissen\"</em></span>\n</div>\n    </div>\n\n    <p><em>„Das Schlimmste? Ich habe 4 Ärzte konsultiert. Hausarzt, Gynäkologin, Endokrinologe, Gastroenterologe. Dutzendes Blutbilder. TSH, Ferritin, Vitamin D, Hormone... Alles normal.\"</em></p>\n\n    <div class=\"pull-quote\">\n      <p>„Wissen Sie, was man mir gesagt hat? ‚Frau K., Ihre Werte sind normal. Das ist möglicherweise psychosomatisch. Haben Sie schon über eine psychotherapeutische Begleitung nachgedacht?' Ich hätte ihnen fast geglaubt. Ich hätte fast akzeptiert, dass ich verrückt bin.\"</p>\n    </div>\n\n    <h2 class=\"section-header\">DIE FRAGE, DIE NIEMAND IHR GESTELLT HATTE</h2>\n\n    <div class=\"img-block\">\n      <div class=\"img-placeholder\">📸 Foto einfügen: Lena mit ihrer Schwägerin — Café-Atmosphäre, natürliches Gespräch</div>\n    </div>\n\n    <p>An einem Abend im September 2025 ist Lena bei ihrer Schwester zum Abendessen. Ihre Schwägerin Petra ist seit 9 Jahren Heilpraktikerin.</p>\n    <p>Nach dem Essen nimmt Petra Lena beiseite.</p>\n    <p><em>„Lena, deine Schwester erzählt mir, dass du seit Monaten erschöpft bist. Aufgeblähter Bauch, Heißhunger, Hautprobleme. Hat dich jemals jemand auf Darmparasiten untersucht?\"</em></p>\n    <p>Lena schaut sie verblüfft an.</p>\n    <p><em>„Parasiten? Wie... Würmer? Aber ich bin doch nicht dreckig! Ich wasche mir die Hände, ich achte auf mein Essen...\"</em></p>\n    <p>Petra lächelt sanft.</p>\n    <p><em>„Genau das glaubt jeder. Dass Parasiten ein Problem armer Länder oder von Menschen sind, die sich nicht waschen. Aber das ist falsch.\"</em></p>\n    <p>Sie zeigt Lena die PLOS-Studie auf ihrem Handy.</p>\n    <p><em>„33,2% der Bevölkerung. Einer von drei. Und in 78% der Fälle erkennen die Routinetests sie nicht.\"</em></p>\n\n    <div class=\"pull-quote\">\n      <p>„In diesem Moment hatte ich einen Aha-Moment. Zum ersten Mal seit 3 Jahren stellte mir jemand eine Frage, die mir NIEMAND — NIEMAND — jemals gestellt hatte.\"</p>\n    </div>\n\n    <h2 class=\"section-header red\">DIE „STILLEN MIETER\", DIE 8 VON 10 ÄRZTEN ÜBERSEHEN</h2>\n\n    <div class=\"img-block\">\n      <div class=\"img-placeholder\">📸 Bild einfügen: medizinische 3D-Animation — Darmparasiten mikroskopisch (Blastocystis, Giardia)</div>\n      <div class=\"img-caption\">Mikroskopische Aufnahme: Blastocystis hominis — einer der häufigsten und am häufigsten übersehenen Darmparasiten in Deutschland.</div>\n    </div>\n\n    <p>Petra erklärt Lena, was sie die „Stillen Mieter\" nennt — diese Parasiten, die sich im Darm einnisten und dort monatelang, manchmal jahrelang leben, ohne dass man es bemerkt.</p>\n\n    <p style=\"font-family: var(--sans); font-size: 15px; font-weight: 700; color: var(--text); margin: 24px 0 12px; letter-spacing: 0.5px;\">Die 3 Arten, wie Parasiten Ihren Körper sabotieren:</p>\n\n    <div class=\"problem-box\">\n      <div class=\"problem-box-title\">Problem #1 — Sie stehlen Ihre Nährstoffe</div>\n      <p>„Parasiten ernähren sich von dem, was Sie essen — bevor Ihr Körper es aufnehmen kann. Vitamine, Mineralien, Aminosäuren... Sie nehmen das Beste. Ergebnis: Sie essen, aber Sie leiden an Mangelerscheinungen. Daher die chronische Erschöpfung, der Gehirnnebel, die fahle Haut.\"</p>\n    </div>\n\n    <div class=\"problem-box\">\n      <div class=\"problem-box-title\">Problem #2 — Sie erzeugen chronische Entzündung</div>\n      <p>„Ihre Anwesenheit reizt die Darmschleimhaut rund um die Uhr. Diese chronische Entzündung breitet sich im gesamten Körper aus: Gelenkschmerzen, reaktive Haut, geschwächtes Immunsystem. Und vor allem verhindert sie Gewichtsverlust — Entzündung blockiert den Stoffwechsel.\"</p>\n    </div>\n\n    <div class=\"problem-box\">\n      <div class=\"problem-box-title\">Problem #3 — Sie setzen Toxine frei</div>\n      <p>„Parasiten produzieren giftige Stoffwechselabfälle, die ins Blut übergehen und die Leber überlasten. Ergebnis: Schlafstörungen, nächtliche Wachphasen (oft zwischen 1 und 3 Uhr — wenn die Leber am intensivsten arbeitet), Reizbarkeit, Konzentrationsprobleme.\"</p>\n    </div>\n\n    <div class=\"doctor-quote\">\n      <p>„Und der Zuckerheißhunger? Parasiten LIEBEN Zucker. Es ist ihr Lieblingstreibstoff. Einige Forscher glauben sogar, dass sie Ihre Nahrungswünsche beeinflussen können, um das zu bekommen, was sie brauchen. Je mehr Zucker Sie essen, desto mehr gedeihen sie. Ein Teufelskreis.\"</p>\n      <div class=\"doctor-name\">— Petra H., Heilpraktikerin für Darmgesundheit, München</div>\n    </div>\n\n    <h2 class=\"section-header\">WARUM IHR ARZT NIEMALS NACHSCHAUT</h2>\n\n    <p>Ich stelle die Frage, die mich brennt.</p>\n    <p><em>„Lena, wenn das so häufig ist — 1 von 3 Menschen — warum untersuchen Ärzte das nicht routinemäßig?\"</em></p>\n\n    <div class=\"symptom-list\">\n      <div class=\"symptom-list-title\">3 Gründe, warum die deutsche Medizin Parasiten ignoriert:</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Veraltete Überzeugung:</strong> „Parasiten sind ein Problem von Entwicklungsländern, nicht von Deutschland.\" Diese Überzeugung stammt aus den 60er Jahren. Aktuelle Studien beweisen das Gegenteil.</span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Unzureichende Tests:</strong> Die Standard-Stuhldiagnostik verfehlt bis zu 78% der Fälle. Parasiten sind nicht immer in jeder Probe vorhanden. PCR-Tests wären nötig, werden aber fast nie verschrieben.</span>\n</div>\n      <div class=\"symptom-item\">\n<span class=\"symptom-icon\">▸</span><span class=\"symptom-text\"><strong>Kein Wundermittel:</strong> Das klassische Wurmmittel Vermox wirkt nur auf bestimmte Wurmarten, nicht auf Protozoen wie Giardia oder Blastocystis. Und es tötet keine Eier — daher die systematischen Rückfälle.</span>\n</div>\n    </div>\n\n    <h2 class=\"section-header\">DIE ENTDECKUNG, DIE ALLES VERÄNDERTE</h2>\n\n    <div class=\"img-block\">\n      <div class=\"img-placeholder\">📸 Bild einfügen: Lena beim Heilpraktiker-Termin, Laborergebnisse in der Hand</div>\n    </div>\n\n    <p>Petra empfiehlt Lena, einen ihrer spezialisierten Kollegen aufzusuchen — einen Heilpraktiker mit 11 Jahren Erfahrung in Darmgesundheit und Parasiteninfektionen.</p>\n    <p>Er ordnet eine vollständige Stuhlanalyse an. Keine Standard-Koprologie. Einen PCR-Test, der Parasiten-DNA erkennt — ob die Erreger an diesem Tag Eier legen oder nicht.</p>\n    <p>Die Ergebnisse kommen eine Woche später.</p>\n\n    <div style=\"background: #fff5f5; border: 2px solid var(--red-alert); border-radius: 6px; padding: 24px; margin: 24px 0; text-align: center;\">\n      <div style=\"font-family: var(--sans); font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red-alert); margin-bottom: 12px;\">TESTERGEBNIS — PCR-ANALYSE</div>\n      <div style=\"font-family: var(--serif); font-size: 20px; font-weight: 700; color: var(--red-alert); margin-bottom: 6px;\">POSITIV — Blastocystis hominis — Hohe Belastung</div>\n      <div style=\"font-family: var(--serif); font-size: 20px; font-weight: 700; color: var(--red-alert);\">POSITIV — Dientamoeba fragilis — Mittlere Belastung</div>\n    </div>\n\n    <p>Zwei Parasitenarten. Beide lebten seit Jahren in Lenas Darm.</p>\n\n    <div class=\"pull-quote\">\n      <p>„Als ich die Ergebnisse sah, habe ich geweint. Nicht vor Traurigkeit. Vor Erleichterung. Endlich hatte ich eine Erklärung. Endlich wusste ich, dass ich nicht verrückt bin.\"</p>\n    </div>\n\n    <p>Jedes einzelne Symptom — jedes davon — hatte dieselbe Ursache.</p>\n    <p><strong>Die Blähungen?</strong> Parasiten produzieren Gase und stören die Darmbewegung.<br>\n    <strong>Die Erschöpfung?</strong> Sie stehlen Eisen, Zink, Magnesium, B-Vitamine.<br>\n    <strong>Die Hautprobleme?</strong> Ihre Abfälle überlasten die Leber — Gifte werden über die Haut ausgeschieden.<br>\n    <strong>Der Gehirnnebel?</strong> Nährstoffmangel + chronische Entzündung.<br>\n    <strong>Der Zuckerheißhunger?</strong> Parasiten manipulieren die Darm-Hirn-Achse.</p>\n\n    <h2 class=\"section-header\">DAS 3-WEGE-PROTOKOLL, DAS PARASITEN ELIMINIERT</h2>\n\n    <div class=\"img-block\">\n      <div class=\"img-placeholder\">📸 Bild einfügen: Heilpraktiker erklärt Lyora-Formel — Amber-Flasche auf Schreibtisch</div>\n    </div>\n\n    <p>Der Heilpraktiker erklärt Lena das Aktionsprotokoll.</p>\n\n    <div class=\"doctor-quote\">\n      <p>„Das Problem mit den meisten Behandlungen — natürliche oder pharmazeutische — ist immer dasselbe: Sie zielen nur auf ein Stadium des Parasitenzyklus ab. Die Erwachsenen. Aber wenn man nicht auch Larven und Eier abtötet, kehren sie in wenigen Wochen zurück. Lyora wirkt auf 3 Wege gleichzeitig.\"</p>\n      <div class=\"doctor-name\">— Dr. M. Weber, Heilpraktiker, Spezialist für Darmgesundheit</div>\n    </div>\n\n    <p style=\"font-family: var(--sans); font-size: 15px; font-weight: 700; margin: 24px 0 16px;\">Die 3 Wirkebenen von Lyora:</p>\n\n    <div class=\"ingredient-card\">\n      <div class=\"ingredient-name\">Weg #1 — Erwachsene Parasiten eliminieren</div>\n      <div class=\"ingredient-dose\">Berberin HCl 83mg</div>\n      <p>„Berberin ist eines der stärksten natürlichen Antiparasitika. Eine im JAMA veröffentlichte Studie zeigte, dass es gegen Giardia genauso wirksam ist wie Metronidazol (das Referenzmedikament) — mit weniger Nebenwirkungen. Es wirkt, indem es die Zellmembran der Parasiten destabilisiert.\"</p>\n    </div>\n\n    <div class=\"ingredient-card\">\n      <div class=\"ingredient-name\">Weg #2 — Eier und Larven zerstören</div>\n      <div class=\"ingredient-dose\">Ingwer 100mg + Kurkuma 100mg</div>\n      <p>„Ingwer und Kurkuma sind nicht nur Entzündungshemmer. Sie haben dokumentierte antiparasitäre Eigenschaften. Ingwer zielt besonders auf unreife Formen (Larven und Eier) ab, die klassische Wurmmittel unangetastet lassen. Das ist der Schlüssel zur Vorbeugung von Rückfällen.\"</p>\n    </div>\n\n    <div class=\"ingredient-card\">\n      <div class=\"ingredient-name\">Weg #3 — Darm reparieren + Leber unterstützen</div>\n      <div class=\"ingredient-dose\">Mariendistel 333mg + Löwenzahn 167mg + Zichorie 83mg</div>\n      <p>„Sobald die Parasiten eliminiert sind, müssen die Schäden behoben werden. Die Darmschleimhaut ist entzündet, die Leber mit Parasitentoxinen überlastet. Mariendistel — 26 klinische Studien — regeneriert Leberzellen. Löwenzahn regt die Gallenproduktion an. Und Zichorie ernährt die guten Bakterien.\"</p>\n    </div>\n\n    <h2 class=\"section-header\">WARUM TROPFEN UND KEINE KAPSELN?</h2>\n\n    <div class=\"img-block\">\n      <div class=\"img-placeholder\">📸 Bild einfügen: Lyora-Flasche, Pipette tropft goldene Flüssigkeit ins Glas — Nahaufnahme</div>\n    </div>\n\n    <div class=\"doctor-quote\">\n      <p>„Es geht um Bioverfügbarkeit. Flüssigextrakte werden zu 80-90% vom Körper aufgenommen. Kapseln? Nur 30-40%. Mit Tropfen unter der Zunge beginnt die Aufnahme sofort über die Mundschleimhaut. Die Wirkstoffe erreichen das Verdauungssystem in wenigen Minuten. Mit einer Kapsel muss man 45 Minuten Verdauung warten — und die Hälfte der Wirkstoffe wird durch die Magensäure zerstört.\"</p>\n      <div class=\"doctor-name\">— Inhaltsstoffe und Bioverfügbarkeit: Nährwertinformationen Lyora</div>\n    </div>\n\n    <h2 class=\"section-header\">DIE 21 TAGE, DIE LENA VERÄNDERT HABEN</h2>\n\n    <p>Zurück im Café bitte ich Lena, mir Tag für Tag zu erzählen, was passiert ist, nachdem sie mit Lyora begonnen hatte.</p>\n\n    <div class=\"timeline\">\n      <div class=\"timeline-item\">\n        <div class=\"timeline-marker\">TAGE<br>1–3</div>\n        <div class=\"timeline-content\">\n          <div class=\"timeline-title\">Die Skepsis</div>\n          <div class=\"timeline-text\">„Ich werde nicht lügen. Die ersten Tage glaubte ich nicht wirklich daran. Ich hatte schon so vieles probiert — Probiotika, Detox-Kuren, Diäten... Ich nahm meine 2 Pipetten morgens in einem Glas Wasser. Leicht bitterer Geschmack, aber erträglich. Und wartete.\"</div>\n        </div>\n      </div>\n      <div class=\"timeline-item\">\n        <div class=\"timeline-marker\">TAG<br>4</div>\n        <div class=\"timeline-content\">\n          <div class=\"timeline-title\">Die erste Überraschung</div>\n          <div class=\"timeline-text\">„Ich wache auf. Ich realisiere etwas Seltsames. Mein Bauch ist... weniger aufgebläht. Mein Mann Markus schaut mich beim Frühstück an: ‚Du siehst heute Morgen weniger müde aus.' Zum ersten Mal seit 2 Jahren ohne Zähneknirschen geschlafen.\"</div>\n        </div>\n      </div>\n      <div class=\"timeline-item\">\n        <div class=\"timeline-marker\">TAG<br>10</div>\n        <div class=\"timeline-content\">\n          <div class=\"timeline-title\">Der Wendepunkt</div>\n          <div class=\"timeline-text\">„Tag 10. Ich wache um 6:45 Uhr auf. Natürlich. Ohne Wecker. Das war seit DREI JAHREN nicht mehr passiert. Aber das Verrückteste? Seit 3 Tagen kein Zuckerheißhunger. Kein unwiderstehlicher Schokodrang um 16 Uhr. Nichts. Da habe ich wirklich angefangen zu glauben.\"</div>\n        </div>\n      </div>\n      <div class=\"timeline-item\">\n        <div class=\"timeline-marker\">TAG<br>14</div>\n        <div class=\"timeline-content\">\n          <div class=\"timeline-title\">Die externe Bestätigung</div>\n          <div class=\"timeline-text\">„Zwei Wochen. Teammeeting im Büro. Meine Kollegin Andrea nimmt mich beiseite: ‚Lena, was hast du gemacht? Deine Haut strahlt. Hast du eine neue Creme?' Ich hatte NICHTS an meiner Schönheitsroutine geändert. NICHTS.\"</div>\n        </div>\n      </div>\n      <div class=\"timeline-item\">\n        <div class=\"timeline-marker\">TAG<br>21</div>\n        <div class=\"timeline-content\">\n          <div class=\"timeline-title\">Die Transformation</div>\n          <div class=\"timeline-text\">„Woche 3. Die Energie ist zurück. Ich bin laufen gegangen. 5 Kilometer. Weinend nach Hause gekommen — weil ich geglaubt hatte, das nie wieder zu schaffen. Der Gehirnnebel hat sich aufgelöst. Ich bin wieder ich.\"</div>\n        </div>\n      </div>\n      <div class=\"timeline-item\">\n        <div class=\"timeline-marker\">WOCHE<br>6</div>\n        <div class=\"timeline-content\">\n          <div class=\"timeline-title\">Der Test — Die Bestätigung</div>\n          <div class=\"timeline-text\">\n            Lena macht eine vollständige PCR-Analyse machen.<br>\n            <strong style=\"color: var(--green);\">Blastocystis hominis: NICHT NACHGEWIESEN.</strong><br>\n            <strong style=\"color: var(--green);\">Dientamoeba fragilis: NICHT NACHGEWIESEN.</strong><br>\n            Ihr Heilpraktiker schaut auf die Ergebnisse und fragt: „Was haben Sie geändert?\" — Er notiert Lyora. Er empfiehlt es jetzt seinen Patienten.\n          </div>\n        </div>\n      </div>\n      <div class=\"timeline-item\">\n        <div class=\"timeline-marker\">MONAT<br>3</div>\n        <div class=\"timeline-content\">\n          <div class=\"timeline-title\">Das Endergebnis</div>\n          <div class=\"timeline-text\">„7 Kilo weniger — ohne Diät, ohne Sport zu ändern. Mein Körper hat das Gewicht einfach losgelassen. Nährstoffwerte normal — zum ersten Mal seit Jahren. Haut vollständig klar. Zähneknirschen komplett weg. Alle Medikamente abgesetzt. Ich laufe wieder Halbmarathon.\"</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- CTA #1 IN ARTICLE -->\n    <div class=\"cta-section\">\n      <div class=\"cta-urgency\">⚡ Zeitlich begrenztes Angebot</div>\n      <div class=\"cta-headlin